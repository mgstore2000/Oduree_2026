    {"type":"checkbox","id":"enable_sticky_gallery","label":"Sticky galerij op desktop","default":true},
    {"type":"select","id":"image_ratio","label":"Afbeeldingsverhouding","options":[{"value":"1/1","label":"Vierkant (1:1)"},{"value":"3/4","label":"Portret (3:4)"},{"value":"4/3","label":"Landschap (4:3)"}],"default":"1/1"},
    {"type":"richtext","id":"shipping_info","label":"Verzendingsinformatie","default":"<ul><li>Gratis verzending boven €50</li><li>2-4 werkdagen levertijd</li><li>30 dagen retour</li></ul>"},
    {"type":"range","id":"recommendations_count","min":2,"max":8,"step":1,"label":"Aantal aanbevelingen","default":4}
