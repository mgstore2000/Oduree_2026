{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
  assign compare_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign on_sale = false
  if compare_price > price
    assign on_sale = true
    assign save_pct = compare_price | minus: price | times: 100.0 | divided_by: compare_price | round
  endif
  assign short_desc = product.metafields.custom.short_description
  if short_desc == blank
    assign short_desc = product.description | strip_html | truncatewords: 40
  endif
-%}

<style>
.pt-wrap{--pt-font-heading:'Helvetica Neue',Helvetica,Arial,sans-serif;--pt-font-body:'Helvetica Neue',Helvetica,Arial,sans-serif;--pt-color-bg:#fff;--pt-color-text:#1a1a1a;--pt-color-text-light:#6b6b6b;--pt-color-accent:#1a1a1a;--pt-color-accent-hover:#333;--pt-color-border:#e5e5e5;--pt-color-bg-light:#f7f7f7;--pt-color-success:#2e7d32;--pt-color-sale:#c62828;--pt-radius:4px;--pt-transition:0.25s cubic-bezier(0.4,0,0.2,1);--pt-max-width:1320px;font-family:var(--pt-font-body);color:var(--pt-color-text);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;background:var(--pt-color-bg);line-height:1.5}
.pt-wrap *,.pt-wrap *::before,.pt-wrap *::after{box-sizing:border-box;margin:0;padding:0}
.pt-container{max-width:var(--pt-max-width);margin:0 auto;padding:0 40px}
.pt-breadcrumb{padding:16px 0;font-size:13px;color:var(--pt-color-text-light)}
.pt-breadcrumb a{color:var(--pt-color-text-light);text-decoration:none;transition:color var(--pt-transition)}
.pt-breadcrumb a:hover{color:var(--pt-color-text)}
.pt-breadcrumb span{margin:0 6px}
.pt-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;padding:24px 0 80px}
.pt-gallery{ {%- if section.settings.enable_sticky_gallery -%}position:sticky;top:24px;{%- endif -%}align-self:start}
.pt-main-image{position:relative;aspect-ratio:{{ section.settings.image_ratio | default: '1/1' }};overflow:hidden;border-radius:var(--pt-radius);background:var(--pt-color-bg-light);cursor:zoom-in}
.pt-main-image img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease}
.pt-main-image:hover img{transform:scale(1.05)}
.pt-sale-badge{position:absolute;top:16px;left:16px;background:var(--pt-color-sale);color:#fff;font-size:12px;font-weight:600;text-transform:uppercase;padding:4px 10px;border-radius:var(--pt-radius);z-index:2;letter-spacing:0.04em}
.pt-thumbnails{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:10px;margin-top:12px}
.pt-thumb{aspect-ratio:1/1;border:2px solid transparent;border-radius:var(--pt-radius);overflow:hidden;cursor:pointer;background:var(--pt-color-bg-light);padding:0;transition:border-color var(--pt-transition)}
.pt-thumb:hover,.pt-thumb.is-active{border-color:var(--pt-color-accent)}
.pt-thumb img{width:100%;height:100%;object-fit:cover;display:block}
.pt-vendor{font-size:12px;text-transform:uppercase;letter-spacing:0.12em;font-weight:500;color:var(--pt-color-text-light);margin-bottom:8px}
.pt-title{font-family:var(--pt-font-heading);font-size:32px;font-weight:500;line-height:1.2;letter-spacing:-0.02em;margin-bottom:12px}
.pt-reviews{display:flex;align-items:center;gap:8px;font-size:14px;margin-bottom:16px}
.pt-stars{color:#f5a623;letter-spacing:2px}
.pt-price-wrap{display:flex;align-items:baseline;gap:12px;padding-bottom:24px;margin-bottom:24px;border-bottom:1px solid var(--pt-color-border)}
.pt-price-current{font-size:28px;font-weight:600}
.pt-price-compare{font-size:18px;text-decoration:line-through;color:var(--pt-color-text-light)}
.pt-price-save{font-size:14px;font-weight:600;color:var(--pt-color-sale);background:#fce4ec;padding:2px 8px;border-radius:var(--pt-radius)}
.pt-short-desc{font-size:15px;line-height:1.7;color:var(--pt-color-text-light);margin-bottom:24px}
.pt-option-group{margin-bottom:20px}
.pt-option-label{font-size:13px;text-transform:uppercase;font-weight:600;letter-spacing:0.06em;margin-bottom:10px;display:block}
.pt-option-label span{font-weight:400;text-transform:none;letter-spacing:0}
.pt-swatches{display:flex;flex-wrap:wrap;gap:10px}
.pt-swatch{width:36px;height:36px;border-radius:50%;border:none;cursor:pointer;transition:transform var(--pt-transition),box-shadow var(--pt-transition);padding:0}
.pt-swatch:hover{transform:scale(1.1)}
.pt-swatch.is-active{box-shadow:0 0 0 2px #fff,0 0 0 4px var(--pt-color-accent)}
.pt-size-btns{display:flex;flex-wrap:wrap;gap:8px}
.pt-size-btn{min-width:48px;height:44px;padding:0 18px;border:1.5px solid var(--pt-color-border);background:transparent;color:var(--pt-color-text);font-size:14px;font-weight:500;cursor:pointer;border-radius:var(--pt-radius);transition:all var(--pt-transition);position:relative;overflow:hidden}
.pt-size-btn:hover{border-color:var(--pt-color-accent)}
.pt-size-btn.is-active{background:var(--pt-color-accent);color:#fff;border-color:var(--pt-color-accent)}
.pt-size-btn.is-soldout{opacity:0.35;cursor:not-allowed}
.pt-size-btn.is-soldout::after{content:'';position:absolute;top:50%;left:-10%;width:120%;height:1.5px;background:var(--pt-color-text);transform:rotate(-12deg)}
.pt-actions{display:flex;gap:12px;margin-bottom:16px}
.pt-qty{display:flex;align-items:center;border:1.5px solid var(--pt-color-border);border-radius:var(--pt-radius)}
.pt-qty button{width:44px;height:52px;border:none;background:transparent;font-size:18px;cursor:pointer;color:var(--pt-color-text);transition:background var(--pt-transition)}
.pt-qty button:hover{background:var(--pt-color-bg-light)}
.pt-qty input{width:48px;height:52px;border:none;text-align:center;font-size:15px;font-family:var(--pt-font-body);-moz-appearance:textfield}
.pt-qty input::-webkit-outer-spin-button,.pt-qty input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
.pt-atc{flex:1;height:52px;background:var(--pt-color-accent);color:#fff;border:none;font-size:15px;text-transform:uppercase;font-weight:600;letter-spacing:0.06em;cursor:pointer;border-radius:var(--pt-radius);transition:all var(--pt-transition);font-family:var(--pt-font-body)}
.pt-atc:hover{background:var(--pt-color-accent-hover)}
.pt-atc:active{transform:scale(0.98)}
.pt-atc:disabled{opacity:0.4;cursor:not-allowed}
.pt-dynamic-btn{margin-bottom:24px}
.pt-dynamic-btn .shopify-payment-button__button{border-radius:var(--pt-radius)!important}
.pt-trust{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;text-align:center;padding:20px 0;border-top:1px solid var(--pt-color-border);border-bottom:1px solid var(--pt-color-border);margin-bottom:24px}
.pt-trust-item{display:flex;flex-direction:column;align-items:center;gap:6px}
.pt-trust-item svg{width:24px;height:24px;stroke:var(--pt-color-text);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.pt-trust-item span{font-size:12px;font-weight:500}
.pt-accordion{border-bottom:1px solid var(--pt-color-border)}
.pt-accordion summary{display:flex;justify-content:space-between;align-items:center;padding:18px 0;font-size:14px;text-transform:uppercase;font-weight:600;letter-spacing:0.03em;cursor:pointer;list-style:none;-webkit-user-select:none;user-select:none}
.pt-accordion summary::-webkit-details-marker{display:none}
.pt-accordion summary::after{content:'+';font-size:20px;font-weight:300;transition:transform var(--pt-transition)}
.pt-accordion[open] summary::after{content:'\2212'}
.pt-accordion-content{padding:0 0 20px;font-size:14px;line-height:1.8;color:var(--pt-color-text-light)}
.pt-accordion-content ul{padding-left:20px}
.pt-accordion-content li{margin-bottom:4px}
.pt-accordion-content table{width:100%;border-collapse:collapse;margin-top:8px;font-size:13px}
.pt-accordion-content th,.pt-accordion-content td{padding:8px 12px;border:1px solid var(--pt-color-border);text-align:center}
.pt-accordion-content th{background:var(--pt-color-bg-light);font-weight:600;text-transform:uppercase;font-size:12px}
.pt-share{display:flex;align-items:center;gap:16px;padding:20px 0;font-size:13px;color:var(--pt-color-text-light)}
.pt-share a{color:var(--pt-color-text-light);text-decoration:none;transition:color var(--pt-transition)}
.pt-share a:hover{color:var(--pt-color-text)}
.pt-recs{padding:60px 0;text-align:center}
.pt-recs-title{font-family:var(--pt-font-heading);font-size:24px;font-weight:500;margin-bottom:32px}
.pt-recs-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:left}
.pt-rec-card{text-decoration:none;color:var(--pt-color-text);display:block}
.pt-rec-img{aspect-ratio:1/1;overflow:hidden;border-radius:var(--pt-radius);background:var(--pt-color-bg-light);margin-bottom:12px}
.pt-rec-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;display:block}
.pt-rec-card:hover .pt-rec-img img{transform:scale(1.05)}
.pt-rec-vendor{font-size:11px;text-transform:uppercase;color:var(--pt-color-text-light);letter-spacing:0.08em}
.pt-rec-name{font-size:14px;font-weight:500;margin:4px 0}
.pt-rec-price{font-size:14px;font-weight:600}
@media(max-width:1024px){.pt-grid{gap:40px}.pt-title{font-size:26px}}
@media(max-width:768px){.pt-grid{grid-template-columns:1fr;gap:32px}.pt-gallery{position:static}.pt-title{font-size:24px}.pt-price-current{font-size:24px}.pt-recs-grid{grid-template-columns:repeat(2,1fr)}.pt-container{padding:0 24px}}
@media(max-width:480px){.pt-container{padding:0 16px}.pt-actions{flex-direction:column}.pt-trust{grid-template-columns:1fr;gap:12px}}
</style>

<div class="pt-wrap">
  <div class="pt-container">

    <nav class="pt-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a><span>/</span>
      {%- if product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title | escape }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
      {%- endif -%}
      <span>/</span>{{ product.title | escape }}
    </nav>

    <div class="pt-grid">

      <div class="pt-gallery" id="pt-gallery">
        <div class="pt-main-image">
          {%- if on_sale -%}<span class="pt-sale-badge">-{{ save_pct }}%</span>{%- endif -%}
          <img id="pt-main-img"
            src="{{ featured_image | image_url: width: 1200 }}"
            alt="{{ featured_image.alt | escape | default: product.title | escape }}"
            width="1200" height="1200" loading="eager">
        </div>
        {%- if product.images.size > 1 -%}
          <div class="pt-thumbnails">
            {%- for image in product.images -%}
              <button type="button" class="pt-thumb{% if forloop.first %} is-active{% endif %}"
                data-image-url="{{ image | image_url: width: 1200 }}"
                aria-label="Toon afbeelding {{ forloop.index }}">
                <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}" width="200" height="200" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="pt-info">

        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p class="pt-vendor">{{ product.vendor | escape }}</p>
        {%- endif -%}

        <h1 class="pt-title">{{ product.title | escape }}</h1>

        {%- if section.settings.show_reviews -%}
          <div class="pt-reviews">
            <span class="pt-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
          </div>
        {%- endif -%}

        <div class="pt-price-wrap" id="pt-price-wrap">
          <span class="pt-price-current" id="pt-price">{{ current_variant.price | money }}</span>
          {%- if on_sale -%}
            <span class="pt-price-compare" id="pt-compare">{{ compare_price | money }}</span>
            <span class="pt-price-save" id="pt-save">-{{ save_pct }}%</span>
          {%- else -%}
            <span class="pt-price-compare" id="pt-compare" style="display:none"></span>
            <span class="pt-price-save" id="pt-save" style="display:none"></span>
          {%- endif -%}
        </div>

        {%- if short_desc != blank -%}
          <p class="pt-short-desc">{{ short_desc }}</p>
        {%- endif -%}

        {%- form 'product', product, id: 'pt-product-form' -%}

          {%- for option in product.options_with_values -%}
            {%- assign opt_name_down = option.name | downcase -%}
            <div class="pt-option-group">
              <label class="pt-option-label">
                {{ option.name }}: <span id="pt-selected-{{ option.name | handleize }}">{{ option.selected_value }}</span>
              </label>

              {%- if opt_name_down == 'color' or opt_name_down == 'kleur' or opt_name_down == 'colour' -%}
                <div class="pt-swatches">
                  {%- for value in option.values -%}
                    <button type="button"
                      class="pt-swatch{% if value == option.selected_value %} is-active{% endif %}"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      data-value="{{ value | escape }}"
                      style="background-color:{{ value | handleize }}"
                      aria-label="{{ value | escape }}">
                    </button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <div class="pt-size-btns">
                  {%- for value in option.values -%}
                    {%- liquid
                      assign soldout = true
                      for v in product.variants
                        case forloop.parentloop.parentloop.index
                          when 1
                            if v.option1 == value and v.available
                              assign soldout = false
                            endif
                          when 2
                            if v.option2 == value and v.available
                              assign soldout = false
                            endif
                          when 3
                            if v.option3 == value and v.available
                              assign soldout = false
                            endif
                        endcase
                      endfor
                    -%}
                    <button type="button"
                      class="pt-size-btn{% if value == option.selected_value %} is-active{% endif %}{% if soldout %} is-soldout{% endif %}"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      data-value="{{ value | escape }}"
                      aria-label="{{ value | escape }}">
                      {{ value | escape }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}

          <select name="id" id="pt-variant-select" style="display:none" aria-label="Variant">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}"
                {% if variant == current_variant %}selected{% endif %}
                data-price="{{ variant.price }}"
                data-compare-price="{{ variant.compare_at_price | default: 0 }}"
                data-available="{{ variant.available }}"
                data-sku="{{ variant.sku | escape }}"
                data-option1="{{ variant.option1 | escape }}" data-option2="{{ variant.option2 | escape }}" data-option3="{{ variant.option3 | escape }}"
                {%- if variant.featured_image -%}data-image="{{ variant.featured_image | image_url: width: 1200 }}"{%- endif -%}>
                {{ variant.title | escape }}
              </option>
            {%- endfor -%}
          </select>

          <div class="pt-actions">
            <div class="pt-qty">
              <button type="button" data-action="decrease" aria-label="Verminder aantal">&#8722;</button>
              <input type="number" name="quantity" id="pt-qty-input" value="1" min="1" aria-label="Aantal">
              <button type="button" data-action="increase" aria-label="Verhoog aantal">+</button>
            </div>
            <button type="submit" class="pt-atc" id="pt-atc-btn"
              {% unless current_variant.available %}disabled{% endunless %}>
              {%- if current_variant.available -%}In winkelwagen{%- else -%}Uitverkocht{%- endif -%}
            </button>
          </div>

          <div class="pt-dynamic-btn">{{ form | payment_button }}</div>

        {%- endform -%}

        <div class="pt-trust">
          <div class="pt-trust-item">
            <svg viewBox="0 0 24 24"><path d="M1 12h5l2.5-7L12 17l3-9 2 5h5"/><rect x="1" y="18" width="22" height="3" rx="1"/></svg>
            <span>Gratis verzending</span>
          </div>
          <div class="pt-trust-item">
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Veilig betalen</span>
          </div>
          <div class="pt-trust-item">
            <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            <span>30 dagen retour</span>
          </div>
        </div>

        <details class="pt-accordion" open>
          <summary>Productomschrijving</summary>
          <div class="pt-accordion-content">{{ product.description }}</div>
        </details>

        {%- if product.metafields.custom.specificaties != blank -%}
          <details class="pt-accordion">
            <summary>Specificaties</summary>
            <div class="pt-accordion-content">{{ product.metafields.custom.specificaties }}</div>
          </details>
        {%- endif -%}

        <details class="pt-accordion">
          <summary>Verzending &amp; Retourneren</summary>
          <div class="pt-accordion-content">
            {%- if section.settings.shipping_info != blank -%}
              {{ section.settings.shipping_info }}
            {%- else -%}
              <ul>
                <li>Gratis verzending boven &euro;50</li>
                <li>2-4 werkdagen levertijd</li>
                <li>Express: volgende werkdag (voor 16:00 besteld)</li>
                <li>30 dagen retour</li>
                <li>Track &amp; Trace</li>
              </ul>
            {%- endif -%}
          </div>
        </details>

        <details class="pt-accordion">
          <summary>Maattabel</summary>
          <div class="pt-accordion-content">
            <table>
              <thead><tr><th>Maat</th><th>XS</th><th>S</th><th>M</th><th>L</th><th>XL</th></tr></thead>
              <tbody><tr><td>Borst (cm)</td><td>82</td><td>88</td><td>94</td><td>100</td><td>106</td></tr></tbody>
            </table>
          </div>
        </details>

        {%- if section.settings.show_share -%}
          {%- assign share_url = shop.url | append: product.url -%}
          {%- assign share_title = product.title | url_encode -%}
          <div class="pt-share">
            <span>Delen:</span>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" aria-label="Deel op Facebook">Facebook</a>
            <a href="https://twitter.com/intent/tweet?url={{ share_url }}&text={{ share_title }}" target="_blank" rel="noopener" aria-label="Deel op X">X</a>
            <a href="https://pinterest.com/pin/create/button/?url={{ share_url }}&description={{ share_title }}" target="_blank" rel="noopener" aria-label="Deel op Pinterest">Pinterest</a>
            <a href="mailto:?subject={{ share_title }}&body={{ share_url }}" aria-label="Deel via e-mail">E-mail</a>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  {%- if recommendations.products_count > 0 -%}
    <div class="pt-container">
      <div class="pt-recs">
        <h2 class="pt-recs-title">Misschien vind je dit ook leuk</h2>
        <div class="pt-recs-grid">
          {%- for rec in recommendations.products limit: section.settings.recommendations_count -%}
            <a href="{{ rec.url }}" class="pt-rec-card">
              <div class="pt-rec-img">
                <img src="{{ rec.featured_image | image_url: width: 600 }}" alt="{{ rec.featured_image.alt | escape }}" width="600" height="600" loading="lazy">
              </div>
              <p class="pt-rec-vendor">{{ rec.vendor | escape }}</p>
              <p class="pt-rec-name">{{ rec.title | escape }}</p>
              <p class="pt-rec-price">{{ rec.price | money }}</p>
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

<script>
(function(){'use strict';
const pd={{ product | json }};
const sel=[...document.querySelectorAll('#pt-variant-select option')].map(o=>({id:+o.value,price:+o.dataset.price,compare:+o.dataset.comparePrice,available:o.dataset.available==='true',image:o.dataset.image||null,opts:[o.dataset.option1,o.dataset.option2,o.dataset.option3]}));
let opts=pd.options.map((_,i)=>pd.selected_or_first_available_variant['option'+(i+1)]);
function fmt(c){return(c/100).toLocaleString('nl-NL',{style:'currency',currency:{{ shop.currency | json }}});}
function updateUI(v){
  if(!v)return;
  document.getElementById('pt-variant-select').value=v.id;
  document.getElementById('pt-price').textContent=fmt(v.price);
  const cmp=document.getElementById('pt-compare'),sv=document.getElementById('pt-save');
  if(v.compare&&v.compare>v.price){const p=Math.round((v.compare-v.price)/v.compare*100);cmp.textContent=fmt(v.compare);cmp.style.display='';sv.textContent='-'+p+'%';sv.style.display='';}else{cmp.style.display='none';sv.style.display='none';}
  const btn=document.getElementById('pt-atc-btn');btn.disabled=!v.available;btn.textContent=v.available?'In winkelwagen':'Uitverkocht';
  if(v.image){document.getElementById('pt-main-img').src=v.image;document.querySelectorAll('.pt-thumb').forEach(t=>{t.classList.toggle('is-active',t.dataset.imageUrl===v.image);});}
  history.replaceState(null,'',location.pathname+'?variant='+v.id);
}
function findVariant(){return sel.find(v=>opts.every((o,i)=>v.opts[i]===o));}
document.querySelectorAll('.pt-swatch,.pt-size-btn').forEach(b=>{b.addEventListener('click',()=>{
  const i=+b.dataset.optionIndex,val=b.dataset.value;opts[i]=val;
  b.closest('.pt-swatches,.pt-size-btns').querySelectorAll('.pt-swatch,.pt-size-btn').forEach(s=>s.classList.remove('is-active'));b.classList.add('is-active');
  const lbl=document.getElementById('pt-selected-'+pd.options[i].toLowerCase().replace(/[^a-z0-9]+/g,'-'));if(lbl)lbl.textContent=val;
  const v=findVariant();if(v)updateUI(v);
});});
document.querySelectorAll('.pt-thumb').forEach(t=>{t.addEventListener('click',()=>{document.querySelectorAll('.pt-thumb').forEach(x=>x.classList.remove('is-active'));t.classList.add('is-active');document.getElementById('pt-main-img').src=t.dataset.imageUrl;});});
const qi=document.getElementById('pt-qty-input');
document.querySelector('[data-action="decrease"]')?.addEventListener('click',()=>{qi.value=Math.max(1,+qi.value-1);});
document.querySelector('[data-action="increase"]')?.addEventListener('click',()=>{qi.value=+qi.value+1;});
})();
</script>

{% schema %}
{
  "name": "Product Template",
  "tag": "section",
  "class": "section-product-template",
  "settings": [
