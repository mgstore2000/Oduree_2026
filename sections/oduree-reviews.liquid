{% render 'oduree-base' %}
<style>
  .od-reviews { padding: 28px 0; text-align: center; }
  .od-reviews__carousel {
    display: flex; gap: 12px; overflow-x: auto; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; scrollbar-width: none; padding: 4px 0;
  }
  .od-reviews__carousel::-webkit-scrollbar { display: none; }
  .od-reviews__card {
    flex-shrink: 0; width: 260px; background: white;
    border: 0.5px solid var(--od-border); border-radius: 12px;
    padding: 16px; display: flex; flex-direction: column; gap: 8px;
    scroll-snap-align: start; text-align: left;
  }
  .od-reviews__stars { display: flex; gap: 3px; }
  .od-reviews__star {
    width: 16px; height: 16px; border-radius: 2px;
    display: flex; align-items: center; justify-content: center;
  }
  .od-reviews__star svg { width: 10px; height: 10px; }
  .od-reviews__title { font-weight: 500; color: var(--od-text); margin-bottom: 4px; font-size: 13px; }
  .od-reviews__text { font-size: 12px; color: var(--od-text-secondary); line-height: 1.55; flex: 1; }
  .od-reviews__bottom { display: flex; align-items: center; gap: 8px; padding-top: 8px; border-top: 0.5px solid #f0ebe3; }
  .od-reviews__avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, #e8e1d5, #ddd6c8);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; color: #999; font-weight: 500; flex-shrink: 0;
  }
  .od-reviews__author { font-size: 11px; color: #aaa; }
  .od-reviews__verified { font-size: 9px; color: var(--od-tp-green); font-weight: 500; }
  .od-reviews__footer { margin-top: 16px; }
  .od-reviews__footer p { font-size: 12px; color: var(--od-text-secondary); }
</style>

<div class="oduree-section od-reviews">
  {%- if section.settings.title != blank -%}
    <p class="od-title">{{ section.settings.title }}</p>
  {%- endif -%}
  <div class="od-reviews__carousel">
    {%- for block in section.blocks -%}
      <div class="od-reviews__card" {{ block.shopify_attributes }}>
        <div class="od-reviews__stars">
          {%- for s in (1..5) -%}
            <div class="od-reviews__star" style="background:{% if s <= block.settings.stars %}var(--od-tp-green){% else %}#ddd{% endif %};">
              <svg viewBox="0 0 12 12" fill="none"><path d="M6 1l1.5 3.1 3.4.3-2.5 2.2.7 3.4L6 8.2 2.9 10l.7-3.4L1.1 4.4l3.4-.3z" fill="white"/></svg>
            </div>
          {%- endfor -%}
        </div>
        {%- if block.settings.title != blank -%}
          <p class="od-reviews__title">{{ block.settings.title }}</p>
        {%- endif -%}
        <p class="od-reviews__text">"{{ block.settings.text }}"</p>
        <div class="od-reviews__bottom">
          <div class="od-reviews__avatar">{{ block.settings.author | slice: 0 }}</div>
          <div>
            <div class="od-reviews__author"><strong>{{ block.settings.author }}</strong>, {{ block.settings.date }}</div>
            <div class="od-reviews__verified">✓ Geverifieerde aankoop</div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
  <div class="od-reviews__footer">
    <p>Beoordeeld met <strong>{{ section.settings.rating }}</strong> / 5 op basis van {{ section.settings.review_count }} reviews</p>
    <div style="display:inline-flex;align-items:center;gap:4px;margin-top:6px;">
      <div class="od-reviews__star" style="width:16px;height:16px;background:var(--od-tp-green);"><svg viewBox="0 0 12 12" fill="none"><path d="M6 1l1.5 3.1 3.4.3-2.5 2.2.7 3.4L6 8.2 2.9 10l.7-3.4L1.1 4.4l3.4-.3z" fill="white"/></svg></div>
      <span style="font-size:12px;font-weight:500;">Trustpilot</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Oduree — Reviews",
  "class": "oduree-reviews-section",
  "settings": [
    { "type": "text", "id": "title", "label": "Titel" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4,5" },
    { "type": "text", "id": "review_count", "label": "Aantal reviews", "default": "3.200+" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "stars", "label": "Sterren", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "textarea", "id": "text", "label": "Review tekst" },
        { "type": "text", "id": "author", "label": "Auteur" },
        { "type": "text", "id": "date", "label": "Datum", "default": "3 dagen geleden" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Oduree — Reviews",
      "blocks": [
        { "type": "review", "settings": { "stars": 5, "title": "Geur blijft lang hangen", "text": "Na 3 weken ruikt mijn auto nog steeds heerlijk. Veel beter dan die dennenbomen van het tankstation.", "author": "Thomas D.", "date": "3 dagen geleden" } },
        { "type": "review", "settings": { "stars": 5, "title": "Ruikt als de echte Sauvage", "text": "Ik draag Dior Sauvage dagelijks en dit is echt een goede match.", "author": "Mohammed A.", "date": "1 week geleden" } },
        { "type": "review", "settings": { "stars": 5, "title": "Perfect cadeau", "text": "Gekocht als cadeau voor mijn vriend. Hij is er helemaal weg van.", "author": "Sophie L.", "date": "2 weken geleden" } },
        { "type": "review", "settings": { "stars": 4, "title": "Goede geur, mooi design", "text": "Looks premium, smells great. Enige minpunt: had iets langer mogen meegaan bij warm weer.", "author": "Jesse v.D.", "date": "3 weken geleden" } }
      ]
    }
  ]
}
{% endschema %}
