.mg-ai-pdp .video-reel { flex-shrink: 0; width: 130px; height: 184px; border-radius: 12px; background: linear-gradient(145deg, #e8e1d5 0%, #ddd6c8 100%); position: relative; overflow: hidden; cursor: pointer; }
.mg-ai-pdp .video-reel-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.mg-ai-pdp .video-play-btn { width: 36px; height: 36px; border-radius: 50%; background: rgba(0,0,0,0.45); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
.mg-ai-pdp .video-reel:hover .video-play-btn { background: rgba(0,0,0,0.6); }
.mg-ai-pdp .video-play-btn svg { width: 14px; height: 14px; fill: white; margin-left: 2px; }
.mg-ai-pdp .video-reel-label { position: absolute; bottom: 0; left: 0; right: 0; padding: 8px 10px; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 100%); color: white; font-size: 10px; font-weight: 500; letter-spacing: 0.2px; }
.mg-ai-pdp .video-section-header { padding: 0 16px; margin-bottom: 10px; font-size: 13px; font-weight: 500; color: #1a1a1a; }

/* ── Sticky Bar ── */
.mg-ai-pdp .sticky-bar { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-top: 0.5px solid #e0e0e0; padding: 10px 20px; display: flex; align-items: center; justify-content: space-between; gap: 12px; z-index: 99; transform: translateY(100%); transition: transform 0.3s ease; }
