.mg-ai-pdp .price-new { font-size: 22px; font-weight: 500; color: #1a1a1a; }
.mg-ai-pdp .price-badge { background: #2C2C2A; color: white; font-size: 11px; font-weight: 500; padding: 3px 9px; border-radius: 5px; display: none; letter-spacing: 0.3px; }

/* ── Option Cards ── */
.mg-ai-pdp .options { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.mg-ai-pdp .opt-card { border: 0.5px solid #ccc; border-radius: 12px; padding: 14px; cursor: pointer; background: white; position: relative; transition: all 0.2s ease; }
.mg-ai-pdp .opt-card:hover { border-color: #aaa; }
.mg-ai-pdp .opt-card.active { border: 2px solid #2C2C2A; box-shadow: 0 2px 12px rgba(44,44,42,0.08); }
.mg-ai-pdp .opt-card .opt-title { font-size: 13px; font-weight: 500; color: #1a1a1a; margin-bottom: 10px; }
.mg-ai-pdp .opt-card .opt-price-single { font-size: 22px; font-weight: 500; color: #1a1a1a; }
.mg-ai-pdp .opt-card .opt-price-row { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.mg-ai-pdp .opt-card .opt-old { font-size: 12px; text-decoration: line-through; color: rgba(68,68,68,0.5); }
.mg-ai-pdp .opt-card .opt-new { font-size: 20px; font-weight: 500; color: #1a1a1a; }
.mg-ai-pdp .opt-card .opt-badge { background: #2C2C2A; color: white; font-size: 10px; padding: 2px 7px; border-radius: 4px; font-weight: 500; }
.mg-ai-pdp .opt-card .opt-sub { font-size: 11px; color: #999; margin-top: 8px; letter-spacing: 0.1px; }
.mg-ai-pdp .most-chosen { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: #2C2C2A; color: white; font-size: 10px; font-weight: 500; padding: 3px 10px; border-radius: 20px; white-space: nowrap; letter-spacing: 0.3px; }

/* ── Abo Section ── */
.mg-ai-pdp .abo-section { background: #F8F2E6; border-radius: 12px; padding: 16px; border: 0.5px solid #E8D9C0; display: none; animation: mgSlideDown 0.3s ease; }
