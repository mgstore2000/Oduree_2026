<div class="mg-ai-pdp" data-product-id="{{ product.id }}" data-section-id="{{ section.id }}">

  <!-- ═══════ IMAGE SLIDER ═══════ -->
  <div class="slider-wrap">
    <div class="img-badge" id="imgBadge">-20%</div>
    <div class="slider-track" id="sliderTrack">
      {%- for image in product.images -%}
        <div class="slide">
          <img src="{{ image | image_url: width: 800 }}"
               alt="{{ image.alt | escape | default: product.title | escape }}"
               width="800" height="800"
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        </div>
      {%- endfor -%}
      {%- if product.images.size == 0 -%}
        <div class="slide"><div class="placeholder">{{ product.title | escape }}</div></div>
      {%- endif -%}
    </div>
    <div class="slider-shadow" id="sliderShadow"></div>
    <button class="slider-arrow prev" id="sliderPrev" disabled aria-label="Previous">
      <svg viewBox="0 0 14 24"><polyline points="12 2 2 12 12 22"/></svg>
    </button>
    <button class="slider-arrow next" id="sliderNext" aria-label="Next">
      <svg viewBox="0 0 14 24"><polyline points="2 2 12 12 2 22"/></svg>
    </button>
    {%- if scent_label != blank -%}
      <div class="img-label">
        <div class="dot"></div>
        <span>{{ scent_label }}</span>
      </div>
    {%- endif -%}
  </div>
  <div class="slider-progress">
    <div class="slider-progress-fill" id="sliderProgress" style="width:{% if product.images.size > 0 %}{{ 100.0 | divided_by: product.images.size }}%{% else %}100%{% endif %};"></div>
  </div>

  <!-- ═══════ THUMBNAILS ═══════ -->
  {%- if product.images.size > 1 -%}
    <div class="thumbs-wrap">
      <div class="thumbs" id="thumbsRow">
        {%- for image in product.images -%}
          <div class="thumb{% if forloop.first %} active{% endif %}" data-slide-index="{{ forloop.index0 }}">
            <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}" width="200" height="200" loading="lazy">
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- ═══════ PRODUCT INFO ═══════ -->
