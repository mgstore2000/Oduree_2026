.mg-ai-pdp .abo-summary .label { font-size: 11px; color: #999; letter-spacing: 0.2px; }
.mg-ai-pdp .abo-summary .val { font-size: 14px; font-weight: 500; color: #1a1a1a; margin-top: 2px; }
.mg-ai-pdp .abo-summary .price-val { font-size: 18px; font-weight: 500; color: #1a1a1a; }

/* ── Buttons ── */
.mg-ai-pdp .btn-primary { width: 100%; background: #C9A84C; color: white; border: none; border-radius: 10px; padding: 15px; font-size: 15px; font-weight: 500; cursor: pointer; letter-spacing: 0.2px; transition: all 0.2s ease; font-family: inherit; }
.mg-ai-pdp .btn-primary:hover { background: #b8963f; }
.mg-ai-pdp .btn-primary:active { transform: scale(0.99); }
.mg-ai-pdp .btn-outline { width: 100%; background: white; color: #1a1a1a; border: 1px solid #c5c5c0; border-radius: 10px; padding: 13px; font-size: 13px; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s ease; font-family: inherit; }
.mg-ai-pdp .btn-outline:hover { border-color: #999; background: #fefefe; }
.mg-ai-pdp .btn-outline .arrow { font-size: 12px; transition: transform 0.3s ease; display: inline-block; }
