        <div class="voordeel"><div class="check"><svg viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><span style="font-size:13px;color:#1a1a1a;">Zelf geuren combineren</span></div>
        <div class="voordeel"><div class="check"><svg viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><span style="font-size:13px;color:#1a1a1a;">Gratis gift bij elke bundel</span></div>
        <div class="voordeel" id="bundelVerzendingVoordeel" style="display:none;"><div class="check"><svg viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><span style="font-size:13px;color:#1a1a1a;">Gratis verzending</span></div>
      </div>

      <button class="btn-primary" id="bundelCartBtn">Bundel toevoegen</button>
    </div>

    <!-- ═══════ LEVERING ═══════ -->
    <p class="info-row">Vandaag besteld → <strong>morgen bezorgd</strong></p>

    <!-- ═══════ SERVICE BENEFITS ═══════ -->
    <div class="trust-row" id="trustRow">&#10003; <span id="shippingText">Verzending vanaf €3,95</span> &nbsp;·&nbsp; &#10003; 30 dagen retour &nbsp;·&nbsp; &#10003; Veilig betalen</div>

    <!-- ═══════ GEUR EXPERIENCE ═══════ -->
    {%- if scent_desc != blank -%}
      <div class="geur-experience">
        <div>
          <p class="geur-exp-title">Over deze geur</p>
          <p class="geur-exp-desc" style="margin-top:8px;">{{ scent_desc }}</p>
        </div>
        {%- if scent_type != blank -%}
          <div class="geur-type-row">
            <span class="geur-type-badge">{{ scent_type }}</span>
            {%- if scent_inspiration != blank -%}
              <span class="geur-type-text">Geïnspireerd op {{ scent_inspiration }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if product.metafields.custom.scent_notes != blank -%}
          <div>
            <p class="geurnoten-label">Geurnoten</p>
            <div class="geurnoten-grid" id="geurnotenGrid"></div>
          </div>
        {%- endif -%}
        <div class="geursterkte-wrap">
          <p class="geurnoten-label">Geursterkte</p>
          <div class="geursterkte-bar">
            <div class="geursterkte-fill" style="width:{{ scent_strength }}%;"></div>
          </div>
          <div class="geursterkte-labels"><span>Licht</span><span>Sterk</span></div>
        </div>
        <div>
          <p class="geurnoten-label">Goed om te weten</p>
          <div class="geur-kenmerken">
            <span class="geur-kenmerk">Intensiteit zelf regelbaar</span>
            <span class="geur-kenmerk kenmerk-with-info">Tot 45 dagen geur <span class="kenmerk-info-icon">i</span>
              <span class="kenmerk-tooltip">De geurduur verschilt per geur en is afhankelijk van temperatuur, ventilatie en gebruik. Uit feedback van 500.000+ verkochte stuks geven klanten gemiddeld 4–6 weken aan.</span>
            </span>
            <span class="geur-kenmerk">Veilig voor je interieur</span>
            <span class="geur-kenmerk">Geen hoofdpijn</span>
            <span class="geur-kenmerk">Past in elke auto</span>
          </div>
        </div>
      </div>
    {%- endif -%}

    <!-- ═══════ VIDEO REELS ═══════ -->
    <div class="video-reels" style="padding:0;">
      <div class="video-reel">
        <div class="video-reel-placeholder"><div class="video-play-btn"><svg viewBox="0 0 14 14"><polygon points="3,1 12,7 3,13"/></svg></div></div>
        <div class="video-reel-label">Unboxing</div>
      </div>
      <div class="video-reel">
        <div class="video-reel-placeholder"><div class="video-play-btn"><svg viewBox="0 0 14 14"><polygon points="3,1 12,7 3,13"/></svg></div></div>
        <div class="video-reel-label">Review</div>
      </div>
      <div class="video-reel">
        <div class="video-reel-placeholder"><div class="video-play-btn"><svg viewBox="0 0 14 14"><polygon points="3,1 12,7 3,13"/></svg></div></div>
        <div class="video-reel-label">In de auto</div>
      </div>
      <div class="video-reel">
        <div class="video-reel-placeholder"><div class="video-play-btn"><svg viewBox="0 0 14 14"><polygon points="3,1 12,7 3,13"/></svg></div></div>
        <div class="video-reel-label">Geur test</div>
      </div>
    </div>

  </div><!-- /.info -->

  <!-- ═══════ STICKY BAR ═══════ -->
  <div class="sticky-bar" id="stickyBar">
    <div class="sticky-prices">
      <span class="sticky-old" id="stickyOld"></span>
      <span class="sticky-new" id="stickyPrice">{{ current_variant.price | money }}</span>
      <span class="sticky-badge" id="stickyBadge">-20%</span>
    </div>
    <button class="sticky-btn" id="stickyBtn">Voeg toe aan winkelwagen</button>
  </div>

</div><!-- /.mg-ai-pdp -->

<script>
(function() {
  'use strict';

  // ─── State ───
  var isAbo = false;
  var bundelOpen = false;
  var isBundelSelected = false;
  var huidigeBundel = 'b1';
  var basePrice = {{ current_variant.price | times: 1.0 | divided_by: 100 }};
  var currentVariantId = {{ current_variant.id }};

  var geuren = [
    {%- for variant in product.variants -%}
      { id: {{ variant.id }}, title: {{ variant.title | json }}, url: {{ variant.url | json }}, price: {{ variant.price | times: 1.0 | divided_by: 100 }}, available: {{ variant.available }} }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ];

  var geurNames = geuren.map(function(g) { return g.title; });

  var bundelBase = {
    b1: { stuks: 2, giftWaarde: 4.95, giftLabel: '1 gift', giftCount: 1 },
    b2: { stuks: 5, giftWaarde: 24.90, giftLabel: '2 gifts', giftCount: 2 },
    b3: { stuks: 10, giftWaarde: 74.80, giftLabel: '4 gifts', giftCount: 4 }
  };
  // Calculate bundel prices dynamically from base price
  Object.keys(bundelBase).forEach(function(k) {
    bundelBase[k].prijs = Math.round(bundelBase[k].stuks * basePrice * 100) / 100;
  });

  {%- if has_selling_plans -%}
  var sellingPlans = [
    {%- for plan in selling_plan_group.selling_plans -%}
      { id: {{ plan.id }}, name: {{ plan.name | json }} }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ];
  {%- else -%}
  var sellingPlans = [];
  {%- endif -%}

  // Scent notes from metafield
  {%- if product.metafields.custom.scent_notes != blank -%}
  try {
    var scentNotes = {{ product.metafields.custom.scent_notes | json }};
    if (typeof scentNotes === 'string') scentNotes = JSON.parse(scentNotes);
    var grid = document.getElementById('geurnotenGrid');
    if (grid && Array.isArray(scentNotes)) {
      scentNotes.forEach(function(note) {
        var div = document.createElement('div');
        div.className = 'geurnoot';
        div.innerHTML = '<span class="geurnoot-icon">' + (note.emoji || '') + '</span><span class="geurnoot-name">' + (note.name || '') + '</span>';
        grid.appendChild(div);
      });
    }
  } catch(e) {}
  {%- endif -%}

  // ─── Helpers ───
  function fmt(n) {
    return '\u20AC' + n.toFixed(2).replace('.', ',');
  }

  function calcBadge(oldP, newP) {
    var diff = oldP - newP;
    if (diff >= 100) return '-\u20AC' + Math.round(diff);
    return '-' + Math.round((diff / oldP) * 100) + '%';
  }

  function $(id) { return document.getElementById(id); }

  // ═══════════════════════════════════════
  // CENTRAL PRICE UPDATE
  // ═══════════════════════════════════════
  function updateAllPrices() {
    var currentBase, currentAbo, beforePrice;
    var isBundel = isBundelSelected && bundelOpen;

    if (isBundel) {
      var bd = bundelBase[huidigeBundel];
      currentBase = bd.prijs;
      currentAbo = Math.round(bd.prijs * 0.8 * 100) / 100;
      beforePrice = Math.round((bd.prijs + bd.giftWaarde) * 100) / 100;
    } else {
      currentBase = basePrice;
      currentAbo = Math.round(basePrice * 0.8 * 100) / 100;
      beforePrice = basePrice;
    }

    var showPrice = isAbo ? currentAbo : currentBase;
    var hasDiscount = isAbo || isBundel;

    // Main price row
    $('priceDisplay').textContent = fmt(showPrice);
    $('oldPrice').textContent = fmt(beforePrice);
    $('oldPrice').style.display = hasDiscount ? 'inline' : 'none';
    $('mainBadge').style.display = hasDiscount ? 'inline' : 'none';
    if (hasDiscount) $('mainBadge').textContent = calcBadge(beforePrice, showPrice);

    // Image badge
    $('imgBadge').style.display = hasDiscount ? 'block' : 'none';
    if (hasDiscount) $('imgBadge').textContent = calcBadge(beforePrice, showPrice);

    // Eenmalig card
    $('optEenmaligPrice').textContent = fmt(currentBase);

    // Abo card
    $('optAboOld').textContent = fmt(isBundel ? beforePrice : currentBase);
    $('optAboNew').textContent = fmt(currentAbo);
    $('optAboBadge').textContent = calcBadge(isBundel ? beforePrice : currentBase, currentAbo);

    // Abo summary
    $('aboSummaryPrice').textContent = fmt(currentAbo);

    // Sticky bar
    $('stickyPrice').textContent = fmt(showPrice);
    $('stickyOld').textContent = fmt(beforePrice);
    $('stickyOld').style.display = hasDiscount ? 'inline' : 'none';
    $('stickyBadge').style.display = hasDiscount ? 'inline' : 'none';
    if (hasDiscount) $('stickyBadge').textContent = calcBadge(beforePrice, showPrice);

    // Bundel cart button
    if (bundelOpen) {
      var bdc = bundelBase[huidigeBundel];
      var bundelPrijs = isAbo ? Math.round(bdc.prijs * 0.8 * 100) / 100 : bdc.prijs;
      $('bundelCartBtn').textContent = isAbo
        ? 'Bundel abonneren \u2014 ' + fmt(bundelPrijs) + '/levering'
        : 'Bundel toevoegen \u2014 ' + fmt(bundelPrijs);
    }

    // Main + sticky button text
    var cartText;
    if (isBundel) {
      var bd2 = bundelBase[huidigeBundel];
      var bp = isAbo ? Math.round(bd2.prijs * 0.8 * 100) / 100 : bd2.prijs;
      cartText = isAbo
        ? 'Bundel abonneren \u2014 ' + fmt(bp) + '/levering'
        : 'Bundel toevoegen \u2014 ' + fmt(bp);
    } else {
      cartText = isAbo ? 'Abonneer & bespaar 20%' : 'Voeg toe aan winkelwagen';
    }
    $('cartBtn').textContent = cartText;
    $('stickyBtn').textContent = cartText;

    // Gratis verzending
    var gratisVerzending = isAbo || showPrice >= 50;
    $('shippingText').textContent = gratisVerzending
      ? 'Gratis verzending'
      : 'Gratis verzending vanaf \u20AC50';
    var bvEl = $('bundelVerzendingVoordeel');
    if (bvEl) {
      var bundelTotaal = bundelBase[huidigeBundel].prijs;
      if (isAbo) bundelTotaal = Math.round(bundelTotaal * 0.8 * 100) / 100;
      bvEl.style.display = (isAbo || bundelTotaal >= 50) ? 'flex' : 'none';
    }
  }

  // ─── Image Slider ───
  var currentSlide = 0;
  var totalSlides = {{ product.images.size | default: 1 }};

  function slideTo(idx) {
    currentSlide = Math.max(0, Math.min(idx, totalSlides - 1));
    var track = $('sliderTrack');
    if (!track || !track.children.length) return;
    var slideW = track.children[0].offsetWidth;
    track.scrollTo({ left: currentSlide * slideW, behavior: 'smooth' });
    updateSliderUI();
  }

  function updateSliderUI() {
    var prog = $('sliderProgress');
    if (prog) prog.style.width = ((currentSlide + 1) / totalSlides * 100) + '%';
    var thumbs = document.querySelectorAll('.mg-ai-pdp .thumb');
    thumbs.forEach(function(t, i) { t.classList.toggle('active', i === currentSlide); });
    var prevBtn = $('sliderPrev');
    var nextBtn = $('sliderNext');
    if (prevBtn) prevBtn.disabled = currentSlide === 0;
    if (nextBtn) nextBtn.disabled = currentSlide === totalSlides - 1;
    var shadow = $('sliderShadow');
    if (shadow) shadow.style.opacity = currentSlide === totalSlides - 1 ? '0' : '1';
    var row = $('thumbsRow');
    if (row && row.children[currentSlide]) {
      row.children[currentSlide].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }
  }

  // Slider arrow clicks
  var prevBtn = $('sliderPrev');
  var nextBtn = $('sliderNext');
  if (prevBtn) prevBtn.addEventListener('click', function() { slideTo(currentSlide - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { slideTo(currentSlide + 1); });

  // Listen to native scroll for swipe detection
  var track = $('sliderTrack');
  if (track) {
    var scrollTimer;
    track.addEventListener('scroll', function() {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function() {
        if (!track.children.length) return;
        var slideW = track.children[0].offsetWidth;
        var newIdx = Math.round(track.scrollLeft / slideW);
        if (newIdx !== currentSlide) {
          currentSlide = newIdx;
          updateSliderUI();
        }
      }, 60);
    }, { passive: true });
  }

  // Thumbnail clicks
  document.querySelectorAll('.mg-ai-pdp .thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var idx = parseInt(thumb.dataset.slideIndex, 10);
      if (!isNaN(idx)) slideTo(idx);
    });
  });

  // ─── Geur kiezer toggle ───
  var geurToggle = $('geurToggleBtn');
  if (geurToggle) {
    geurToggle.addEventListener('click', function() {
      var picker = $('geurPicker');
      if (!picker) return;
      var isOpen = picker.style.display !== 'none';
      picker.style.display = isOpen ? 'none' : 'block';
      geurToggle.classList.toggle('open', !isOpen);
    });
  }

  // Geur pill click
  document.querySelectorAll('.mg-ai-pdp .geur-pill').forEach(function(pill) {
    pill.addEventListener('click', function(e) {
      e.preventDefault();
      document.querySelectorAll('.mg-ai-pdp .geur-pill').forEach(function(p) { p.classList.remove('active'); });
      pill.classList.add('active');
      var url = pill.getAttribute('href');
      if (url) window.location.href = url;
    });
  });

  // Tooltip toggle on mobile
  document.querySelectorAll('.mg-ai-pdp .kenmerk-with-info').forEach(function(el) {
    el.addEventListener('click', function() {
      el.classList.toggle('show-tooltip');
    });
  });

  // ─── Period selector ───
  function selectPeriod(id, label) {
    ['p1', 'p2', 'p3', 'p4'].forEach(function(p) {
      var el = $(p);
      if (!el || el.style.display === 'none') return;
      el.classList.remove('active');
      el.style.border = '1px solid #d8cdb8';
    });
    var sel = $(id);
    if (sel) {
      sel.classList.add('active');
      sel.style.border = '2px solid #2C2C2A';
    }
    $('aboSummaryPeriod').textContent = label;
  }

  // Period button clicks
  document.querySelectorAll('.mg-ai-pdp .period-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      selectPeriod(btn.id, btn.dataset.label || btn.textContent);
    });
  });

  // ─── Update period tabs based on bundel ───
  function updatePeriodTabs() {
    var grid = $('periodGrid');
    var p4 = $('p4');
    if (!grid || !p4) return;

    if (isBundelSelected && bundelOpen) {
      p4.style.display = '';
      grid.style.gridTemplateColumns = 'repeat(4, 1fr)';
      var preselect = { b1: ['p2', 'Elke 2 maanden'], b2: ['p3', 'Elke 3 maanden'], b3: ['p4', 'Elke 6 maanden'] };
      var ps = preselect[huidigeBundel];
      if (ps) selectPeriod(ps[0], ps[1]);
    } else {
      p4.style.display = 'none';
      grid.style.gridTemplateColumns = 'repeat(3, 1fr)';
      selectPeriod('p1', 'Elke maand');
    }
  }

  // ─── Eenmalig / Abo toggle ───
  function selectOpt(opt) {
    isAbo = opt === 'abo';
    var optE = $('optEenmalig');
    var optA = $('optAbo');
    if (optE) { optE.classList.toggle('active', !isAbo); optE.style.border = isAbo ? '0.5px solid #ccc' : '2px solid #2C2C2A'; }
    if (optA) { optA.classList.toggle('active', isAbo); optA.style.border = isAbo ? '2px solid #2C2C2A' : '0.5px solid #ccc'; }

    var aboSec = $('aboSection');
    if (aboSec) aboSec.style.display = isAbo ? 'block' : 'none';
    if (isAbo) updatePeriodTabs();

    if (bundelOpen) {
      var badge = $('aboBundelBadge');
      if (badge) badge.style.display = isAbo ? 'flex' : 'none';
      updateBundelCardPrices();
    }
    updateAllPrices();
  }

  // Option card clicks
  var optE = $('optEenmalig');
  var optA = $('optAbo');
  if (optE) optE.addEventListener('click', function() { selectOpt('eenmalig'); });
  if (optA) optA.addEventListener('click', function() { selectOpt('abo'); });

  // ─── Bundel card prices ───
  function updateBundelCardPrices() {
    Object.keys(bundelBase).forEach(function(id) {
      var d = bundelBase[id];
      var beforePrijs = Math.round((d.prijs + d.giftWaarde) * 100) / 100;
      var afterPrijs = isAbo ? Math.round(d.prijs * 0.8 * 100) / 100 : d.prijs;
      var oldEl = $(id + '-old');
      var newEl = $(id + '-new');
      var badgeEl = $(id + '-badge');
      if (oldEl) { oldEl.style.display = 'inline'; oldEl.textContent = fmt(beforePrijs); }
      if (newEl) newEl.textContent = fmt(afterPrijs);
      if (badgeEl) { badgeEl.style.display = 'inline'; badgeEl.textContent = calcBadge(beforePrijs, afterPrijs); }
    });
  }

  // ─── Bundel toggle ───
  function toggleBundel() {
    bundelOpen = !bundelOpen;
    var sec = $('bundelSection');
    var arrow = $('bundelArrow');
    if (sec) sec.style.display = bundelOpen ? 'block' : 'none';
    if (arrow) arrow.style.transform = bundelOpen ? 'rotate(180deg)' : 'rotate(0)';

    if (bundelOpen) {
      updateBundelCardPrices();
      buildGeurSlots(bundelBase[huidigeBundel].stuks);
      updateGiftUnlocks(bundelBase[huidigeBundel].stuks);
      isBundelSelected = true;
    } else {
      isBundelSelected = false;
    }

    var aboBadge = $('aboBundelBadge');
    if (aboBadge) aboBadge.style.display = (bundelOpen && isAbo) ? 'flex' : 'none';
    updatePeriodTabs();
    updateAllPrices();
  }

  var bundelToggle = $('bundelToggleBtn');
  if (bundelToggle) bundelToggle.addEventListener('click', toggleBundel);

  // ─── Select bundel card ───
  function selectBundel(id, stuks) {
    Object.keys(bundelBase).forEach(function(b) {
      var el = $(b);
      if (el) { el.classList.remove('active'); el.style.border = '0.5px solid #ccc'; }
    });
    var sel = $(id);
    if (sel) { sel.classList.add('active'); sel.style.border = '2px solid #2C2C2A'; }
    huidigeBundel = id;
    isBundelSelected = true;
    buildGeurSlots(stuks);
    updateGiftUnlocks(stuks);
    updatePeriodTabs();
    updateAllPrices();
  }

  // Bundel card clicks
  document.querySelectorAll('.mg-ai-pdp .bundel-card').forEach(function(card) {
    card.addEventListener('click', function() {
      selectBundel(card.id, parseInt(card.dataset.stuks, 10));
    });
  });

  // ─── Gift unlock logic ───
  var giftConfig = [
    { id: 'gift1', minStuks: 2 },
    { id: 'gift2', minStuks: 5 },
    { id: 'gift3', minStuks: 10 },
    { id: 'gift4', minStuks: 10 }
  ];

  function updateGiftUnlocks(stuks) {
    giftConfig.forEach(function(g) {
      var el = $(g.id);
      if (!el) return;
      var unlocked = stuks >= g.minStuks;
      el.classList.toggle('unlocked', unlocked);
      el.classList.toggle('locked', !unlocked);
      var badge = el.querySelector('.gift-gratis-badge');
      if (badge) {
        if (unlocked) {
          badge.textContent = 'Gratis';
          badge.classList.remove('locked-badge');
        } else {
          badge.textContent = 'Bij ' + g.minStuks + (g.minStuks < 10 ? '+' : '');
          badge.classList.add('locked-badge');
        }
      }
      var lock = el.querySelector('.gift-lock-overlay');
      if (lock) lock.style.display = unlocked ? 'none' : 'flex';
    });
  }

  // ─── Build geur dropdowns ───
  function buildGeurSlots(aantal) {
    var c = $('geurSlots');
    var countEl = $('geurAantal');
    if (countEl) countEl.textContent = aantal;
    if (!c) return;
    c.innerHTML = '';
    for (var i = 0; i < aantal; i++) {
      var row = document.createElement('div');
      row.className = 'geur-slot';
      var lbl = document.createElement('label');
      lbl.textContent = 'Geur ' + (i + 1);
      var sel = document.createElement('select');
      geurNames.forEach(function(g, idx) {
        var opt = document.createElement('option');
        opt.value = g;
        opt.textContent = g;
        sel.appendChild(opt);
      });
      sel.selectedIndex = i % geurNames.length;
      row.appendChild(lbl);
      row.appendChild(sel);
      c.appendChild(row);
    }
  }

  // ─── Add to Cart (Shopify AJAX API) ───
  function addToCart(variantId, qty, sellingPlanId) {
    var body = { id: variantId, quantity: qty };
    if (sellingPlanId) body.selling_plan = sellingPlanId;

    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(body)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status) {
        console.error('Cart error:', data.description);
        return;
      }
      window.location.href = '/cart';
    })
    .catch(function(err) { console.error('Add to cart failed:', err); });
  }

  function getSelectedSellingPlan() {
    if (!isAbo || sellingPlans.length === 0) return null;
    return sellingPlans[0].id;
  }

  // Main ATC button
  var cartBtn = $('cartBtn');
  if (cartBtn) {
    cartBtn.addEventListener('click', function() {
      var isBundel = isBundelSelected && bundelOpen;
      var spId = getSelectedSellingPlan();

      if (isBundel) {
        // Add multiple items for bundle
        var stuks = bundelBase[huidigeBundel].stuks;
        var slots = document.querySelectorAll('#geurSlots select');
        var items = [];
        slots.forEach(function(sel) {
          var name = sel.value;
          var variant = geuren.find(function(g) { return g.title === name; });
          if (variant) {
            var existing = items.find(function(it) { return it.id === variant.id; });
            if (existing) { existing.quantity++; }
            else {
              var item = { id: variant.id, quantity: 1 };
              if (spId) item.selling_plan = spId;
              items.push(item);
            }
          }
        });
        if (items.length === 0) {
          items.push({ id: currentVariantId, quantity: stuks });
          if (spId) items[0].selling_plan = spId;
        }
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: items })
        })
        .then(function(r) { return r.json(); })
        .then(function() { window.location.href = '/cart'; })
        .catch(function(err) { console.error('Bundle add failed:', err); });
      } else {
        addToCart(currentVariantId, 1, spId);
      }
    });
  }

  // Bundel ATC button
  var bundelBtn = $('bundelCartBtn');
  if (bundelBtn) {
    bundelBtn.addEventListener('click', function() {
      cartBtn.click();
    });
  }

  // Sticky button
  var stickyBtn = $('stickyBtn');
  if (stickyBtn) {
    stickyBtn.addEventListener('click', function() {
      if (cartBtn) {
        cartBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  }

  // ─── Sticky bar: show when main ATC is out of view ───
  var stickyBar = $('stickyBar');
  if (cartBtn && stickyBar && 'IntersectionObserver' in window) {
    var stickyObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        stickyBar.classList.toggle('visible', !entry.isIntersecting);
      });
    }, { threshold: 0 });
    stickyObs.observe(cartBtn);
  }

  // ─── Init ───
  updateAllPrices();

})();
</script>

