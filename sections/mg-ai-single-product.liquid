{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_type = product.type | default: 'Autoparfum'

  assign scent_desc = product.metafields.custom.scent_description
  if scent_desc == blank
    assign scent_desc = product.description | strip_html | truncatewords: 60
  endif
  assign scent_type = product.metafields.custom.scent_type | default: ''
  assign scent_strength = product.metafields.custom.scent_strength | default: 75
  assign scent_inspiration = product.metafields.custom.scent_inspiration | default: ''
  assign scent_label = product.metafields.custom.scent_label | default: ''

  assign selling_plan_group = product.selling_plan_groups | first
  assign has_selling_plans = false
  if selling_plan_group != blank
    assign has_selling_plans = true
  endif
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display&display=swap" rel="stylesheet">

<style>
/* ── Reset & Base ── */
.mg-ai-pdp { max-width: 480px; width: 100%; margin: 0 auto; font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Proxima Nova', sans-serif; color: #1a1a1a; line-height: 1.45; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
.mg-ai-pdp *, .mg-ai-pdp *::before, .mg-ai-pdp *::after { box-sizing: border-box; margin: 0; padding: 0; }
.mg-ai-pdp img { display: block; max-width: 100%; height: auto; }

/* ── Image Slider ── */
.mg-ai-pdp .slider-wrap { position: relative; width: 100%; overflow: hidden; background: #f2ede5; }
.mg-ai-pdp .slider-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; -ms-overflow-style: none; }
.mg-ai-pdp .slider-track::-webkit-scrollbar { display: none; }
.mg-ai-pdp .slide { min-width: 100%; aspect-ratio: 1 / 1; background: #f2ede5; display: flex; align-items: center; justify-content: center; position: relative; scroll-snap-align: start; flex-shrink: 0; }
.mg-ai-pdp .slide img { width: 100%; height: 100%; object-fit: cover; }
.mg-ai-pdp .slide .placeholder { width: 55%; height: 55%; background: rgba(255,255,255,0.3); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #bbb; font-size: 12px; letter-spacing: 0.5px; }
.mg-ai-pdp .img-badge { position: absolute; top: 14px; right: 14px; background: #2C2C2A; color: white; padding: 4px 10px; border-radius: 5px; font-size: 12px; font-weight: 500; letter-spacing: 0.3px; display: none; z-index: 3; }
.mg-ai-pdp .slider-shadow { position: absolute; top: 0; right: 0; width: 60px; height: 100%; background: linear-gradient(to left, rgba(242,237,229,0.7) 0%, transparent 100%); z-index: 2; pointer-events: none; }
.mg-ai-pdp .img-label { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(248,242,230,0.92); backdrop-filter: blur(8px); padding: 10px 16px; display: flex; align-items: center; gap: 8px; z-index: 3; }
.mg-ai-pdp .img-label .dot { width: 10px; height: 10px; border-radius: 50%; background: #8B6A4F; flex-shrink: 0; box-shadow: 0 0 0 2px rgba(139,106,79,0.2); }
.mg-ai-pdp .img-label span { font-size: 11px; color: #666; letter-spacing: 0.2px; }
.mg-ai-pdp .slider-arrow { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; z-index: 4; padding: 12px 8px; transition: opacity 0.2s; }
.mg-ai-pdp .slider-arrow svg { width: 14px; height: 24px; stroke: rgba(44,44,42,0.4); stroke-width: 1.5; fill: none; stroke-linecap: round; stroke-linejoin: round; }
.mg-ai-pdp .slider-arrow:hover svg { stroke: rgba(44,44,42,0.8); }
.mg-ai-pdp .slider-arrow.next { right: 6px; }
.mg-ai-pdp .slider-arrow.prev { left: 6px; }
.mg-ai-pdp .slider-arrow:disabled { opacity: 0; pointer-events: none; }
.mg-ai-pdp .slider-progress { width: 40%; height: 2px; background: #e0d8cc; margin: 8px auto 0; border-radius: 1px; overflow: hidden; }
.mg-ai-pdp .slider-progress-fill { height: 100%; background: #2C2C2A; border-radius: 1px; transition: width 0.3s ease; }

/* ── Thumbnails ── */
.mg-ai-pdp .thumbs-wrap { position: relative; padding: 10px 16px 4px; }
.mg-ai-pdp .thumbs { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; }
.mg-ai-pdp .thumbs::-webkit-scrollbar { display: none; }
.mg-ai-pdp .thumb { width: 68px; height: 68px; flex-shrink: 0; border-radius: 6px; border: 1.5px solid transparent; background: linear-gradient(135deg, #ede8df 0%, #e5ddd0 100%); cursor: pointer; transition: all 0.2s ease; overflow: hidden; }
.mg-ai-pdp .thumb img { width: 100%; height: 100%; object-fit: cover; }
.mg-ai-pdp .thumb:hover { border-color: #c5b9a8; }
.mg-ai-pdp .thumb.active { border: 2px solid #2C2C2A; }

/* ── Info Container ── */
.mg-ai-pdp .info { padding: 0 16px; margin-top: 8px; display: flex; flex-direction: column; gap: 14px; }

/* ── Trustpilot ── */
.mg-ai-pdp .trustpilot { display: inline-flex; align-items: center; gap: 8px; align-self: flex-start; }
.mg-ai-pdp .tp-stars { display: flex; gap: 2px; }
.mg-ai-pdp .tp-star { width: 20px; height: 20px; background: #00B67A; display: flex; align-items: center; justify-content: center; border-radius: 2px; }
.mg-ai-pdp .tp-star svg { width: 12px; height: 12px; }
.mg-ai-pdp .tp-info { font-size: 12px; color: #555; letter-spacing: 0.1px; }
.mg-ai-pdp .tp-info strong { font-weight: 600; color: #1a1a1a; }

/* ── Title ── */
.mg-ai-pdp .product-subtitle { font-size: 12px; color: #999; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 400; }
.mg-ai-pdp .product-title { font-family: 'DM Serif Display', Georgia, serif; font-size: 26px; font-weight: 400; color: #1a1a1a; margin-top: 2px; letter-spacing: -0.3px; }
.mg-ai-pdp .geur-toggle { background: none; border: none; font-family: inherit; font-size: 12px; color: #888; cursor: pointer; padding: 0; margin-top: 6px; display: inline-flex; align-items: center; gap: 4px; transition: color 0.15s; text-decoration: underline; text-decoration-color: rgba(136,136,136,0.3); text-underline-offset: 2px; }
.mg-ai-pdp .geur-toggle:hover { color: #555; }
.mg-ai-pdp .geur-toggle svg { transition: transform 0.2s; }
.mg-ai-pdp .geur-toggle.open svg { transform: rotate(180deg); }

/* ── Geur picker ── */
.mg-ai-pdp .geur-picker { animation: mgSlideDown 0.25s ease; }
.mg-ai-pdp .geur-pills { display: flex; flex-wrap: wrap; gap: 6px; }
.mg-ai-pdp .geur-pill { padding: 6px 12px; border-radius: 20px; border: 1px solid #ddd; background: white; font-size: 12px; color: #555; cursor: pointer; transition: all 0.15s ease; font-family: inherit; white-space: nowrap; text-decoration: none; }
.mg-ai-pdp .geur-pill:hover { border-color: #aaa; color: #1a1a1a; }
.mg-ai-pdp .geur-pill.active { background: #2C2C2A; color: white; border-color: #2C2C2A; }

/* ── Product Benefits ── */
.mg-ai-pdp .product-benefits { display: flex; flex-direction: column; gap: 7px; }
.mg-ai-pdp .benefit-item { display: flex; align-items: center; gap: 8px; }
.mg-ai-pdp .benefit-item svg { flex-shrink: 0; opacity: 0.7; }
.mg-ai-pdp .benefit-item span { font-size: 13px; color: #555; letter-spacing: 0.1px; }

/* ── Price Row ── */
.mg-ai-pdp .price-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
