        {%- endfor -%}
      </div>
      <span class="tp-info"><strong>{{ section.settings.tp_rating | default: '4,5' }}</strong> · {{ section.settings.tp_text | default: '200.000+ Tevreden Gebruikers' }}</span>
    </div>

    <!-- Titel -->
    <div>
      <p class="product-subtitle">{{ product_type }}</p>
      <h1 class="product-title">{{ product.title | escape }}</h1>
      {%- if product.variants.size > 1 -%}
