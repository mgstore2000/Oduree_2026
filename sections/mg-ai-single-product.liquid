.mg-ai-pdp .kenmerk-tooltip { display: none; position: absolute; bottom: calc(100% + 10px); left: 0; background: #000; color: #fff; font-size: 13px; line-height: 1.6; padding: 14px 16px; border-radius: 10px; width: 280px; z-index: 10; box-shadow: 0 6px 24px rgba(0,0,0,0.25); font-weight: 400; }
.mg-ai-pdp .kenmerk-tooltip::after { content: ''; position: absolute; top: 100%; left: 24px; border: 6px solid transparent; border-top-color: #000; }
.mg-ai-pdp .kenmerk-with-info:hover .kenmerk-tooltip,
.mg-ai-pdp .kenmerk-with-info.show-tooltip .kenmerk-tooltip { display: block; }
.mg-ai-pdp .kenmerk-tooltip.tooltip-down { bottom: auto; top: calc(100% + 10px); }
.mg-ai-pdp .kenmerk-tooltip.tooltip-down::after { top: auto; bottom: 100%; border-top-color: transparent; border-bottom-color: #000; }

/* ── Video Reels ── */
.mg-ai-pdp .video-reels { display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; padding: 0; }
