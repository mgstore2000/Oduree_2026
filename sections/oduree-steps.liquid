{% render 'oduree-base' %}
<style>
  .od-steps { padding: 28px 0; }
  .od-steps__list { display: flex; flex-direction: column; gap: 16px; }
  .od-steps__item { display: flex; gap: 14px; align-items: flex-start; }
  .od-steps__num {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--od-dark); color: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 600; flex-shrink: 0;
  }
  .od-steps__text { font-size: 13px; color: var(--od-text-secondary); line-height: 1.5; padding-top: 3px; }
  .od-steps__text strong { color: var(--od-text); }
  @media (min-width: 750px) {
    .od-steps__list { flex-direction: row; gap: 24px; }
    .od-steps__item { flex: 1; flex-direction: column; text-align: center; align-items: center; }
  }
</style>

<div class="oduree-section od-steps">
  {%- if section.settings.title != blank -%}
    <p class="od-title">{{ section.settings.title }}</p>
  {%- endif -%}
  <div class="od-steps__list">
    {%- for block in section.blocks -%}
      <div class="od-steps__item" {{ block.shopify_attributes }}>
        <div class="od-steps__num">{{ forloop.index }}</div>
        <div class="od-steps__text"><strong>{{ block.settings.title }}</strong> — {{ block.settings.text }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Oduree — Stappen",
  "class": "oduree-steps-section",
  "settings": [
    { "type": "text", "id": "title", "label": "Titel", "default": "In 3 stappen genieten" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Stap",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "textarea", "id": "text", "label": "Beschrijving" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Oduree — Stappen",
      "blocks": [
        { "type": "step", "settings": { "title": "Kies je geur", "text": "Van fris en sportief tot warm en verfijnd. Elke geur is geïnspireerd op iconische parfums." } },
        { "type": "step", "settings": { "title": "Hang het op", "text": "Bevestig de autoparfum aan je achteruitkijkspiegel. Klaar in 5 seconden." } },
        { "type": "step", "settings": { "title": "Stel de intensiteit in", "text": "Draai de dop losser voor meer geur, strakker voor minder. Jij bepaalt." } }
      ]
    }
  ]
}
{% endschema %}
