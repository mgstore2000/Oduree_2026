<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display&display=swap" rel="stylesheet">

<style>
  /* ═══════════════════════════════════════
     RESET & VARIABLES
     ═══════════════════════════════════════ */
  .oduree-product {
    --color-bg: {{ section.settings.page_background_color }};
    --color-text: {{ section.settings.text_color }};
    --color-accent: {{ section.settings.accent_color }};
    --color-atc: {{ section.settings.atc_button_color }};
    --color-atc-text: {{ section.settings.atc_button_text_color }};
    --font-body: 'DM Sans', sans-serif;
    --font-display: 'DM Serif Display', serif;
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    max-width: 480px;
    margin: 0 auto;
    padding: 0 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ─── Typography ─── */
  .oduree-product__title { font-family: var(--font-display); font-size: clamp(1.4rem, 5vw, 1.75rem); line-height: 1.2; margin-bottom: 2px; }
  .oduree-product__subtitle { font-size: 13px; color: #888; margin-bottom: 8px; }

  /* ─── Trustpilot ─── */
  .oduree-tp { display: flex; align-items: center; gap: 6px; font-size: 12px; margin-bottom: 12px; }
  .oduree-tp__stars { letter-spacing: 1px; }
  .oduree-tp__rating { font-weight: 600; }
  .oduree-tp__text { opacity: 0.65; }

  /* ─── Gallery ─── */
  .oduree-gallery { position: relative; width: calc(100% + 32px); margin-left: -16px; margin-bottom: 16px; overflow: hidden; background: #f5f0e8; aspect-ratio: 1/1; }
  .oduree-gallery__track { display: flex; transition: transform 0.3s ease; height: 100%; }
  .oduree-gallery__slide { min-width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .oduree-gallery__slide img { width: 100%; height: 100%; object-fit: cover; }
  .oduree-gallery__dots { position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); display: flex; gap: 6px; }
  .oduree-gallery__dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.5); border: none; cursor: pointer; padding: 0; }
  .oduree-gallery__dot--active { background: #fff; }
  .oduree-gallery__nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.85); border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; }
  .oduree-gallery__nav--prev { left: 8px; }
  .oduree-gallery__nav--next { right: 8px; }
  .oduree-gallery__thumbs { display: flex; gap: 6px; padding: 8px 16px; overflow-x: auto; }
  .oduree-gallery__thumb { width: 56px; height: 56px; border-radius: 6px; object-fit: cover; border: 2px solid transparent; cursor: pointer; flex-shrink: 0; }
  .oduree-gallery__thumb--active { border-color: var(--color-accent); }

  /* ─── Benefits ─── */
  .oduree-benefits { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .oduree-benefit { display: flex; align-items: center; gap: 8px; font-size: 13px; }
  .oduree-benefit__icon { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .oduree-benefit__tooltip-trigger { cursor: help; border-bottom: 1px dashed #bbb; position: relative; }
  .oduree-benefit__tooltip { display: none; position: absolute; bottom: 100%; left: 0; background: #333; color: #fff; padding: 8px 12px; border-radius: 6px; font-size: 11px; width: 240px; z-index: 10; line-height: 1.4; }
  .oduree-benefit__tooltip-trigger:hover .oduree-benefit__tooltip,
  .oduree-benefit__tooltip-trigger:focus .oduree-benefit__tooltip { display: block; }

  /* ─── Price ─── */
  .oduree-price { display: flex; align-items: baseline; gap: 8px; margin-bottom: 4px; }
  .oduree-price__current { font-family: var(--font-display); font-size: clamp(1.6rem, 6vw, 2rem); }
  .oduree-price__compare { text-decoration: line-through; color: #999; font-size: 14px; }
  .oduree-price__badge { background: #e74c3c; color: #fff; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 20px; }
  .oduree-price__unit { font-size: 12px; color: #888; margin-bottom: 12px; }

  /* ─── Toggle (eenmalig/abo) ─── */
  .oduree-toggle { display: flex; border: 1.5px solid #e0d8cc; border-radius: 10px; overflow: hidden; margin-bottom: 16px; }
  .oduree-toggle__option { flex: 1; text-align: center; padding: 10px 8px; font-size: 13px; cursor: pointer; background: transparent; border: none; transition: background 0.2s; position: relative; font-family: inherit; }
  .oduree-toggle__option--active { background: var(--color-accent); color: #fff; font-weight: 600; }
  .oduree-toggle__badge { position: absolute; top: -10px; right: 8px; background: #e74c3c; color: #fff; font-size: 9px; padding: 1px 6px; border-radius: 8px; font-weight: 600; }

  /* ─── Variant selector ─── */
  .oduree-variants__label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
  .oduree-variants__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-bottom: 16px; }
  .oduree-variant-card { border: 1.5px solid #e0d8cc; border-radius: 8px; padding: 8px 4px; text-align: center; cursor: pointer; transition: border-color 0.2s; background: #fff; }
  .oduree-variant-card--active { border-color: var(--color-accent); box-shadow: 0 0 0 1px var(--color-accent); }
  .oduree-variant-card__dot { width: 18px; height: 18px; border-radius: 50%; margin: 0 auto 4px; }
  .oduree-variant-card__name { font-size: 10px; font-weight: 500; }

  /* ─── ATC Button ─── */
  .oduree-atc { width: 100%; padding: 14px; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; letter-spacing: 0.5px; cursor: pointer; background: var(--color-atc); color: var(--color-atc-text); margin-bottom: 12px; transition: opacity 0.2s; font-family: inherit; }
  .oduree-atc:hover { opacity: 0.9; }
  .oduree-atc:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ─── Bundel ─── */
  .oduree-bundel__toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border: 1.5px solid #e0d8cc; border-radius: 10px; background: transparent; cursor: pointer; font-size: 13px; font-weight: 500; margin-bottom: 4px; font-family: inherit; }
  .oduree-bundel__sub { font-size: 11px; color: #888; text-align: center; margin-bottom: 12px; }
  .oduree-bundel__panel { display: none; border: 1.5px solid #e0d8cc; border-radius: 12px; padding: 14px; margin-bottom: 16px; }
  .oduree-bundel__panel--open { display: block; }
  .oduree-bundel__heading { font-family: var(--font-display); font-size: 16px; margin-bottom: 10px; }

  /* ─── Geur experience ─── */
  .oduree-geur { border: 1px solid #e0d8cc; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
  .oduree-geur__title { font-family: var(--font-display); font-size: 16px; margin-bottom: 6px; }
  .oduree-geur__badges { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
  .oduree-geur__badge { font-size: 10px; padding: 3px 10px; border: 1px solid #e0d8cc; border-radius: 20px; background: transparent; }
  .oduree-geur__desc { font-size: 13px; line-height: 1.6; color: #555; margin-bottom: 14px; }
  .oduree-geur__noten { display: flex; gap: 12px; justify-content: center; margin-bottom: 14px; }
  .oduree-geurnoot { text-align: center; }
  .oduree-geurnoot__icon { font-size: 11px; opacity: 0.7; display: block; margin-bottom: 2px; }
  .oduree-geurnoot__name { font-size: 11px; font-weight: 500; }
  .oduree-geur__strength { margin-top: 10px; }
  .oduree-geur__strength-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
  .oduree-geur__strength-bar { height: 6px; background: #e8e0d0; border-radius: 3px; overflow: hidden; }
  .oduree-geur__strength-fill { height: 100%; background: var(--color-accent); border-radius: 3px; transition: width 0.3s; }
  .oduree-geur__strength-text { font-size: 11px; color: #888; margin-top: 2px; }

  /* ─── Delivery / Trust ─── */
  .oduree-delivery { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #2a7d2e; margin-bottom: 8px; }
  .oduree-trust-row { font-size: 12px; color: #666; text-align: center; margin-bottom: 16px; padding: 8px 0; }

  /* ═══════════════════════════════════════
     BELOW-FOLD BLOCKS
     ═══════════════════════════════════════ */
  .oduree-below-fold { max-width: 480px; width: 100%; padding: 0; }
  .oduree-section-block { padding: 24px 0; border-bottom: 1px solid #ede8df; }
  .oduree-section-block__title { font-family: var(--font-display); font-size: clamp(1.1rem, 4vw, 1.3rem); text-align: center; margin-bottom: 6px; }
  .oduree-section-block__subtitle { font-size: 13px; color: #888; text-align: center; margin-bottom: 16px; }

  /* ─── Social Proof ─── */
  .oduree-social-proof__stats { display: flex; justify-content: space-around; gap: 8px; margin-top: 12px; }
  .oduree-social-proof__divider { width: 0.5px; background: #e0d8cc; }
  .oduree-stat__value { font-family: var(--font-display); font-size: 22px; text-align: center; }
  .oduree-stat__label { font-size: 11px; color: #888; text-align: center; }

  /* ─── Lifestyle Image ─── */
  .oduree-lifestyle { position: relative; border-radius: 12px; overflow: hidden; min-height: 220px; }
  .oduree-lifestyle img { width: 100%; height: 100%; object-fit: cover; }
  .oduree-lifestyle__overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px; color: #fff; background: linear-gradient(transparent, rgba(0,0,0,0.6)); }
  .oduree-lifestyle__overlay p { font-family: var(--font-display); font-size: 20px; margin-bottom: 4px; }
  .oduree-lifestyle__overlay span { font-size: 13px; opacity: 0.85; }

  /* ─── USP Row ─── */
  .oduree-usp-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; padding: 16px 0; }
  .oduree-usp-item { text-align: center; }
  .oduree-usp-item__icon { font-size: 24px; margin-bottom: 4px; }
  .oduree-usp-item__label { font-size: 12px; font-weight: 600; }
  .oduree-usp-item__desc { font-size: 11px; color: #888; }

  /* ─── Steps ─── */
  .oduree-steps { display: flex; flex-direction: column; gap: 12px; }
  .oduree-step { display: flex; gap: 12px; align-items: flex-start; }
  .oduree-step__num { width: 28px; height: 28px; border-radius: 50%; background: var(--color-accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; flex-shrink: 0; }
  .oduree-step__text { font-size: 13px; line-height: 1.5; }

  /* ─── Stats Grid ─── */
  .oduree-stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .oduree-stat-card { background: #fff; border-radius: 10px; padding: 16px; text-align: center; border: 1px solid #ede8df; }
  .oduree-stat-card__value { font-family: var(--font-display); font-size: 24px; }
  .oduree-stat-card__label { font-size: 11px; color: #888; margin-top: 2px; }

  /* ─── Quote ─── */
  .oduree-quote-card { background: #fff; border: 1px solid #ede8df; border-radius: 12px; padding: 20px; text-align: center; }
  .oduree-quote-card__stars { color: #f5a623; font-size: 16px; margin-bottom: 8px; }
  .oduree-quote-card__text { font-size: 14px; font-style: italic; line-height: 1.6; margin-bottom: 10px; }
  .oduree-quote-card__author { font-size: 12px; color: #888; }

  /* ─── FAQ ─── */
  .oduree-faq-item { border-bottom: 1px solid #ede8df; padding: 12px 0; cursor: pointer; }
  .oduree-faq-item__question { display: flex; justify-content: space-between; align-items: center; font-size: 14px; font-weight: 500; }
  .oduree-faq-item__icon { font-size: 18px; transition: transform 0.2s; flex-shrink: 0; }
  .oduree-faq-item--open .oduree-faq-item__icon { transform: rotate(45deg); }
  .oduree-faq-item__answer { display: none; font-size: 13px; color: #666; line-height: 1.6; padding-top: 8px; }
  .oduree-faq-item--open .oduree-faq-item__answer { display: block; }

  /* ─── Comparison Table ─── */
  .oduree-compare-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .oduree-compare-table th { padding: 8px 6px; text-align: center; font-size: 11px; font-weight: 600; }
  .oduree-compare-table td { padding: 8px 6px; text-align: center; border-top: 1px solid #ede8df; }
  .oduree-compare-table td:first-child { text-align: left; font-weight: 500; }
  .oduree-compare-col-brand { background: rgba(201,168,76,0.08); color: var(--color-accent); font-weight: 600; }

  /* ─── Reviews Carousel ─── */
  .oduree-review-scroll { display: flex; gap: 12px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding-bottom: 8px; }
  .oduree-review-card { min-width: 260px; scroll-snap-align: start; background: #fff; border: 1px solid #ede8df; border-radius: 10px; padding: 16px; flex-shrink: 0; }
  .oduree-review-card__stars { color: #f5a623; font-size: 14px; margin-bottom: 6px; }
  .oduree-review-card__text { font-size: 13px; line-height: 1.5; margin-bottom: 10px; }
  .oduree-review-card__bottom { display: flex; align-items: center; gap: 8px; }
  .oduree-review-card__avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--color-accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; }
  .oduree-review-card__author { font-size: 12px; font-weight: 600; }
  .oduree-review-card__verified { font-size: 10px; color: #2a7d2e; }

  /* ─── Brand Story ─── */
  .oduree-brand-block { border-radius: 12px; overflow: hidden; }
  .oduree-brand-block__img { height: 200px; display: flex; align-items: center; justify-content: center; color: #888; font-size: 14px; }
  .oduree-brand-block__img img { width: 100%; height: 100%; object-fit: cover; }
  .oduree-brand-block__text { padding: 20px; }
  .oduree-brand-block__text h3 { font-family: var(--font-display); font-size: 18px; margin-bottom: 8px; }
  .oduree-brand-block__text p { font-size: 13px; line-height: 1.6; opacity: 0.85; }

  /* ─── Use Cases ─── */
  .oduree-usecase-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .oduree-usecase-card { border-radius: 10px; overflow: hidden; text-align: center; border: 1px solid #ede8df; }
  .oduree-usecase-card__img { height: 100px; background: #f5f0e8; display: flex; align-items: center; justify-content: center; font-size: 28px; }
  .oduree-usecase-card__img img { width: 100%; height: 100%; object-fit: cover; }
  .oduree-usecase-card__label { padding: 8px; font-size: 12px; font-weight: 500; }

  /* ─── Cross-sell ─── */
  .oduree-crosssell-scroll { display: flex; gap: 12px; overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 8px; }
  .oduree-crosssell-card { min-width: 160px; flex-shrink: 0; border: 1px solid #ede8df; border-radius: 10px; overflow: hidden; background: #fff; }
  .oduree-crosssell-card__img { height: 140px; display: flex; align-items: center; justify-content: center; background: #f5f0e8; }
  .oduree-crosssell-card__img img { width: 100%; height: 100%; object-fit: cover; }
  .oduree-crosssell-card__info { padding: 10px; }
  .oduree-crosssell-card__name { font-size: 12px; font-weight: 600; margin-bottom: 4px; }
  .oduree-crosssell-card__price { font-size: 12px; }
  .oduree-crosssell-card__price .old { text-decoration: line-through; color: #999; margin-right: 4px; }
  .oduree-crosssell-card__btn { display: block; width: 100%; text-align: center; padding: 8px; font-size: 11px; font-weight: 600; border: none; border-top: 1px solid #ede8df; background: transparent; cursor: pointer; color: var(--color-accent); text-decoration: none; }

  /* ─── CTA Banner ─── */
  .oduree-cta-banner { border-radius: 12px; padding: 24px 16px; text-align: center; }
  .oduree-cta-banner__title { font-family: var(--font-display); font-size: 18px; margin-bottom: 6px; }
  .oduree-cta-banner__sub { font-size: 13px; opacity: 0.8; margin-bottom: 14px; }
  .oduree-cta-banner__btn { padding: 12px 28px; border: none; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; color: #fff; font-family: inherit; }

  /* ─── Trust Footer ─── */
  .oduree-trust-footer { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; padding: 16px 0; }
  .oduree-trust-footer__item { display: flex; align-items: center; gap: 6px; font-size: 12px; }

  /* ─── Sticky Bar ─── */
  .oduree-sticky-bar { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-top: 1px solid #e0d8cc; padding: 10px 16px; display: none; align-items: center; justify-content: space-between; z-index: 100; }
  .oduree-sticky-bar--visible { display: flex; }
  .oduree-sticky-bar__prices { display: flex; align-items: baseline; gap: 6px; }
  .oduree-sticky-bar__old { text-decoration: line-through; color: #999; font-size: 12px; }
  .oduree-sticky-bar__price { font-weight: 700; font-size: 16px; }
  .oduree-sticky-bar__btn { padding: 10px 20px; border: none; border-radius: 8px; font-weight: 600; font-size: 13px; cursor: pointer; background: var(--color-atc); color: var(--color-atc-text); font-family: inherit; }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (min-width: 750px) {
    .oduree-product { max-width: 1200px; padding: 0 40px; }
    .oduree-above-fold { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    .oduree-gallery { width: 100%; margin-left: 0; border-radius: 12px; }
    .oduree-product-info { position: sticky; top: 20px; }
    .oduree-benefits { flex-direction: row; flex-wrap: wrap; gap: 12px; }
    .oduree-below-fold { max-width: 800px; margin: 0 auto; }
    .oduree-stats-grid { grid-template-columns: repeat(4, 1fr); }
    .oduree-usp-row { gap: 16px; }
    {% if section.settings.sticky_buy_button_mobile_only %}
    .oduree-sticky-bar { display: none !important; }
    {% endif %}
  }
  @media (max-width: 749px) {
    .oduree-above-fold { display: flex; flex-direction: column; }
    .oduree-gallery__nav { display: none; }
    {% unless section.settings.sticky_buy_button_enabled %}
    .oduree-sticky-bar { display: none !important; }
    {% endunless %}
  }
</style>

{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="oduree-product" style="margin-top:{{ section.settings.margin_top }}px;margin-bottom:{{ section.settings.margin_bottom }}px;">

<div class="oduree-above-fold">
  <!-- ════════════ GALLERY ════════════ -->
  <div>
    <div class="oduree-gallery" id="odureeGallery">
      <div class="oduree-gallery__track" id="galleryTrack">
        {%- for media in product.media -%}
          <div class="oduree-gallery__slide">
            {%- if media.media_type == 'image' -%}
              <img src="{{ media | image_url: width: 800 }}" alt="{{ media.alt | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="800" height="800">
            {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
              {{ media | media_tag: autoplay: section.settings.enable_video_autoplay, loop: section.settings.enable_video_looping, controls: true }}
            {%- else -%}
              {{ media | media_tag }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <button class="oduree-gallery__nav oduree-gallery__nav--prev" onclick="odureeSlider(-1)" aria-label="Vorige">&lsaquo;</button>
      <button class="oduree-gallery__nav oduree-gallery__nav--next" onclick="odureeSlider(1)" aria-label="Volgende">&rsaquo;</button>
      <div class="oduree-gallery__dots" id="galleryDots">
        {%- for media in product.media -%}
          <button class="oduree-gallery__dot{% if forloop.first %} oduree-gallery__dot--active{% endif %}" onclick="odureeGoTo({{ forloop.index0 }})" aria-label="Slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    </div>
    {%- if product.media.size > 1 -%}
    <div class="oduree-gallery__thumbs">
      {%- for media in product.media -%}
        {%- if media.media_type == 'image' -%}
          <img class="oduree-gallery__thumb{% if forloop.first %} oduree-gallery__thumb--active{% endif %}" src="{{ media | image_url: width: 120 }}" alt="{{ media.alt | escape }}" onclick="odureeGoTo({{ forloop.index0 }})" loading="lazy">
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>

  <!-- ════════════ PRODUCT INFO ════════════ -->
  <div class="oduree-product-info">

    {%- if section.settings.trustpilot_enabled -%}
    <div class="oduree-tp">
      <span class="oduree-tp__stars" style="color:{{ section.settings.trustpilot_stars_color }};">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="oduree-tp__rating">{{ section.settings.trustpilot_rating }}</span>
      <span class="oduree-tp__text">{{ section.settings.trustpilot_text }}</span>
    </div>
    {%- endif -%}

    <h1 class="oduree-product__title">{{ product.title }}</h1>
    {%- if product.metafields.descriptors.subtitle -%}
      <p class="oduree-product__subtitle">{{ product.metafields.descriptors.subtitle }}</p>
    {%- endif -%}

    {%- assign benefit_blocks = section.blocks | where: "type", "benefit" -%}
    {%- if benefit_blocks.size > 0 -%}
    <div class="oduree-benefits">
      {%- for block in benefit_blocks -%}
        <div class="oduree-benefit" {{ block.shopify_attributes }}>
          <span class="oduree-benefit__icon">
            {%- case block.settings.benefit_icon -%}
              {%- when 'checkmark' -%}&#10003;
              {%- when 'shield' -%}&#128737;
              {%- when 'clock' -%}&#9201;
              {%- when 'heart' -%}&#9829;
              {%- when 'star' -%}&#9733;
              {%- when 'truck' -%}&#128666;
              {%- when 'gift' -%}&#127873;
            {%- endcase -%}
          </span>
          {%- if block.settings.benefit_tooltip_enabled and block.settings.benefit_tooltip_text != blank -%}
            <span class="oduree-benefit__tooltip-trigger" tabindex="0">
              {{ block.settings.benefit_text }}
              <span class="oduree-benefit__tooltip">{{ block.settings.benefit_tooltip_text }}</span>
            </span>
          {%- else -%}
            <span>{{ block.settings.benefit_text }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <div class="oduree-price">
      <span class="oduree-price__current" id="odureePriceCurrent">{{ current_variant.price | money }}</span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <span class="oduree-price__compare" id="odureePriceCompare">{{ current_variant.compare_at_price | money }}</span>
        {%- assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
        <span class="oduree-price__badge" id="odureePriceBadge">-{{ discount_pct }}%</span>
      {%- endif -%}
    </div>
    {%- if current_variant.unit_price -%}
      <p class="oduree-price__unit">{{ current_variant.unit_price | money }} / {{ current_variant.unit_price_measurement.reference_unit }}</p>
    {%- endif -%}

    {%- if section.settings.show_subscription_option -%}
    <div class="oduree-toggle" id="odureeToggle">
      <button class="oduree-toggle__option oduree-toggle__option--active" data-mode="onetime" onclick="odureeSetMode('onetime')" type="button">
        {{ section.settings.onetime_label }}
      </button>
      <button class="oduree-toggle__option" data-mode="abo" onclick="odureeSetMode('abo')" type="button">
        {{ section.settings.subscription_label }}
        <span class="oduree-toggle__badge">{{ section.settings.subscription_badge_text }}</span>
      </button>
    </div>
    {%- endif -%}

    {%- if product.variants.size > 1 -%}
    <p class="oduree-variants__label">{{ section.settings.variant_selector_label }}</p>
    <div class="oduree-variants__grid" id="odureeVariants">
      {%- for variant in product.variants -%}
        <div class="oduree-variant-card{% if variant == current_variant %} oduree-variant-card--active{% endif %}"
             data-variant-id="{{ variant.id }}"
             data-variant-price="{{ variant.price }}"
             data-variant-compare="{{ variant.compare_at_price }}"
             data-variant-available="{{ variant.available }}"
             onclick="odureeSelectVariant(this)">
          {%- if section.settings.show_variant_color_dot -%}
            {%- assign swatch_color = variant.metafields.custom.color | default: '#ccc' -%}
            <div class="oduree-variant-card__dot" style="background:{{ swatch_color }};"></div>
          {%- endif -%}
          <div class="oduree-variant-card__name">{{ variant.title }}</div>
        </div>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <form method="post" action="/cart/add" id="odureeForm">
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="odureeVariantInput">
      <button type="submit" class="oduree-atc" id="odureeATC"{% unless current_variant.available %} disabled{% endunless %}>
        {%- if current_variant.available -%}
          {{ section.settings.atc_button_text }}
        {%- else -%}
          Uitverkocht
        {%- endif -%}
      </button>
    </form>

    {%- if section.settings.bundel_enabled -%}
    <div class="oduree-bundel">
      <button class="oduree-bundel__toggle" onclick="odureeBundelToggle()" type="button">
        <span>{{ section.settings.bundel_button_text }}</span>
        <span id="odureeBundelArrow">&#x25BE;</span>
      </button>
      <p class="oduree-bundel__sub">{{ section.settings.bundel_sub_text }}</p>
      <div class="oduree-bundel__panel" id="odureeBundelPanel">
        <p class="oduree-bundel__heading">{{ section.settings.bundel_heading }}</p>
      </div>
    </div>
    {%- endif -%}

    <div class="oduree-delivery">
      <span>&#x1F69A;</span>
      <span>{{ section.settings.delivery_text }}</span>
    </div>

    <div class="oduree-geur">
      <p class="oduree-geur__title">{{ section.settings.geur_exp_title }}</p>
      <div class="oduree-geur__badges">
        <span class="oduree-geur__badge">{{ section.settings.geur_type_badge }}</span>
        <span class="oduree-geur__badge">{{ section.settings.geur_inspiration_text }}</span>
      </div>
      <p class="oduree-geur__desc">{{ section.settings.geur_exp_desc }}</p>
      <div class="oduree-geur__noten">
        {%- if section.settings.geurnoot_1_name != blank -%}
          <div class="oduree-geurnoot"><span class="oduree-geurnoot__icon">{{ section.settings.geurnoot_1_label }}</span><span class="oduree-geurnoot__name">{{ section.settings.geurnoot_1_name }}</span></div>
        {%- endif -%}
        {%- if section.settings.geurnoot_2_name != blank -%}
          <div class="oduree-geurnoot"><span class="oduree-geurnoot__icon">{{ section.settings.geurnoot_2_label }}</span><span class="oduree-geurnoot__name">{{ section.settings.geurnoot_2_name }}</span></div>
        {%- endif -%}
        {%- if section.settings.geurnoot_3_name != blank -%}
          <div class="oduree-geurnoot"><span class="oduree-geurnoot__icon">{{ section.settings.geurnoot_3_label }}</span><span class="oduree-geurnoot__name">{{ section.settings.geurnoot_3_name }}</span></div>
        {%- endif -%}
        {%- if section.settings.geurnoot_4_name != blank -%}
          <div class="oduree-geurnoot"><span class="oduree-geurnoot__icon">{{ section.settings.geurnoot_4_label }}</span><span class="oduree-geurnoot__name">{{ section.settings.geurnoot_4_name }}</span></div>
        {%- endif -%}
      </div>
      <div class="oduree-geur__strength">
        <p class="oduree-geur__strength-label">Geursterkte</p>
        <div class="oduree-geur__strength-bar">
          <div class="oduree-geur__strength-fill" style="width:{{ section.settings.geur_strength_percentage }}%;"></div>
        </div>
        <p class="oduree-geur__strength-text">{{ section.settings.geur_strength_label }}</p>
      </div>
    </div>

    <div class="oduree-trust-row">
      &#10003; {{ section.settings.trust_row_text }} &nbsp;&middot;&nbsp; &#10003; {{ section.settings.trust_row_secondary }}
    </div>

  </div>
</div>

<!-- ════════════ BELOW-FOLD BLOCKS ════════════ -->
<div class="oduree-below-fold">
{%- for block in section.blocks -%}
  {%- case block.type -%}

  {%- when 'social_proof' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <div class="oduree-social-proof__stats">
        <div><div class="oduree-stat__value">{{ block.settings.stat_1_value }}</div><div class="oduree-stat__label">{{ block.settings.stat_1_label }}</div></div>
        <div class="oduree-social-proof__divider"></div>
        <div><div class="oduree-stat__value">{{ block.settings.stat_2_value }}</div><div class="oduree-stat__label">{{ block.settings.stat_2_label }}</div></div>
        <div class="oduree-social-proof__divider"></div>
        <div><div class="oduree-stat__value">{{ block.settings.stat_3_value }}</div><div class="oduree-stat__label">{{ block.settings.stat_3_label }}</div></div>
      </div>
    </div>

  {%- when 'lifestyle_image' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <div class="oduree-lifestyle">
        {%- if block.settings.image -%}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="800">
        {%- else -%}
          <div style="height:220px;background:linear-gradient(135deg,#3a3835,#2a2724);display:flex;align-items:center;justify-content:center;color:#888;font-size:14px;">Lifestyle foto</div>
        {%- endif -%}
        <div class="oduree-lifestyle__overlay">
          <p>{{ block.settings.heading }}</p>
          <span>{{ block.settings.subheading }}</span>
        </div>
      </div>
    </div>

  {%- when 'usp_row' -%}
    <div class="oduree-usp-row" {{ block.shopify_attributes }}>
      <div class="oduree-usp-item"><div class="oduree-usp-item__icon">{{ block.settings.usp_1_icon }}</div><div class="oduree-usp-item__label">{{ block.settings.usp_1_label }}</div><div class="oduree-usp-item__desc">{{ block.settings.usp_1_desc }}</div></div>
      <div class="oduree-usp-item"><div class="oduree-usp-item__icon">{{ block.settings.usp_2_icon }}</div><div class="oduree-usp-item__label">{{ block.settings.usp_2_label }}</div><div class="oduree-usp-item__desc">{{ block.settings.usp_2_desc }}</div></div>
      <div class="oduree-usp-item"><div class="oduree-usp-item__icon">{{ block.settings.usp_3_icon }}</div><div class="oduree-usp-item__label">{{ block.settings.usp_3_label }}</div><div class="oduree-usp-item__desc">{{ block.settings.usp_3_desc }}</div></div>
    </div>

  {%- when 'how_it_works' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <div class="oduree-steps">
        <div class="oduree-step"><div class="oduree-step__num">1</div><div class="oduree-step__text"><strong>{{ block.settings.step_1_title }}</strong> &mdash; {{ block.settings.step_1_text }}</div></div>
        <div class="oduree-step"><div class="oduree-step__num">2</div><div class="oduree-step__text"><strong>{{ block.settings.step_2_title }}</strong> &mdash; {{ block.settings.step_2_text }}</div></div>
        <div class="oduree-step"><div class="oduree-step__num">3</div><div class="oduree-step__text"><strong>{{ block.settings.step_3_title }}</strong> &mdash; {{ block.settings.step_3_text }}</div></div>
      </div>
    </div>

  {%- when 'proven_results' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <p class="oduree-section-block__subtitle">{{ block.settings.subtitle }}</p>
      <div class="oduree-stats-grid">
        <div class="oduree-stat-card"><div class="oduree-stat-card__value">{{ block.settings.stat_1_value }}</div><div class="oduree-stat-card__label">{{ block.settings.stat_1_label }}</div></div>
        <div class="oduree-stat-card"><div class="oduree-stat-card__value">{{ block.settings.stat_2_value }}</div><div class="oduree-stat-card__label">{{ block.settings.stat_2_label }}</div></div>
        <div class="oduree-stat-card"><div class="oduree-stat-card__value">{{ block.settings.stat_3_value }}</div><div class="oduree-stat-card__label">{{ block.settings.stat_3_label }}</div></div>
        <div class="oduree-stat-card"><div class="oduree-stat-card__value">{{ block.settings.stat_4_value }}</div><div class="oduree-stat-card__label">{{ block.settings.stat_4_label }}</div></div>
      </div>
    </div>

  {%- when 'testimonial_quote' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <div class="oduree-quote-card">
        <div class="oduree-quote-card__stars">{%- for i in (1..block.settings.star_rating) -%}&#9733;{%- endfor -%}</div>
        <div class="oduree-quote-card__text">&ldquo;{{ block.settings.quote_text }}&rdquo;</div>
        <div class="oduree-quote-card__author">&mdash; {{ block.settings.quote_author }}</div>
      </div>
    </div>

  {%- when 'faq' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <div class="oduree-faq-list">
        {%- for i in (1..6) -%}
          {%- assign q_key = 'faq_question_' | append: i -%}
          {%- assign a_key = 'faq_answer_' | append: i -%}
          {%- if block.settings[q_key] != blank -%}
          <div class="oduree-faq-item" onclick="this.classList.toggle('oduree-faq-item--open')">
            <div class="oduree-faq-item__question">{{ block.settings[q_key] }}<span class="oduree-faq-item__icon">+</span></div>
            <div class="oduree-faq-item__answer">{{ block.settings[a_key] }}</div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  {%- when 'comparison_table' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <table class="oduree-compare-table">
        <thead><tr><th></th><th class="oduree-compare-col-brand">{{ block.settings.brand_name }}</th><th>{{ block.settings.competitor_1 }}</th><th>{{ block.settings.competitor_2 }}</th></tr></thead>
        <tbody>
          {%- for i in (1..5) -%}
            {%- assign label_key = 'row_' | append: i | append: '_label' -%}
            {%- if block.settings[label_key] != blank -%}
            {%- assign oduree_key = 'row_' | append: i | append: '_oduree' -%}
            {%- assign comp1_key = 'row_' | append: i | append: '_comp1' -%}
            {%- assign comp2_key = 'row_' | append: i | append: '_comp2' -%}
            <tr>
              <td>{{ block.settings[label_key] }}</td>
              <td class="oduree-compare-col-brand">{{ block.settings[oduree_key] }}</td>
              <td>{{ block.settings[comp1_key] }}</td>
              <td>{{ block.settings[comp2_key] }}</td>
            </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>

  {%- when 'reviews_carousel' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <div class="oduree-review-scroll">
        {%- for i in (1..3) -%}
          {%- assign text_key = 'review_' | append: i | append: '_text' -%}
          {%- assign author_key = 'review_' | append: i | append: '_author' -%}
          {%- assign initials_key = 'review_' | append: i | append: '_initials' -%}
          {%- if block.settings[text_key] != blank -%}
          <div class="oduree-review-card">
            {%- if block.settings.show_star_rating -%}<div class="oduree-review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>{%- endif -%}
            <div class="oduree-review-card__text">{{ block.settings[text_key] }}</div>
            <div class="oduree-review-card__bottom">
              <div class="oduree-review-card__avatar">{{ block.settings[initials_key] }}</div>
              <div><div class="oduree-review-card__author">{{ block.settings[author_key] }}</div><div class="oduree-review-card__verified">&#10003; Geverifieerd</div></div>
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  {%- when 'brand_story' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <div class="oduree-brand-block" style="background:{{ block.settings.background_color | default: '#2C2C2A' }};color:{{ block.settings.text_color | default: '#FFFFFF' }};">
        <div class="oduree-brand-block__img">
          {%- if block.settings.image -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
          {%- else -%}
            Merkfoto
          {%- endif -%}
        </div>
        <div class="oduree-brand-block__text">
          <h3>{{ block.settings.heading }}</h3>
          {{ block.settings.body_text }}
        </div>
      </div>
    </div>

  {%- when 'use_cases' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      <div class="oduree-usecase-grid">
        {%- for i in (1..4) -%}
          {%- assign img_key = 'case_' | append: i | append: '_image' -%}
          {%- assign label_key = 'case_' | append: i | append: '_label' -%}
          {%- if block.settings[label_key] != blank -%}
          <div class="oduree-usecase-card">
            <div class="oduree-usecase-card__img">
              {%- if block.settings[img_key] -%}
                <img src="{{ block.settings[img_key] | image_url: width: 400 }}" alt="{{ block.settings[label_key] | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="oduree-usecase-card__label">{{ block.settings[label_key] }}</div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  {%- when 'cross_sell' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <p class="oduree-section-block__title">{{ block.settings.heading }}</p>
      {%- if block.settings.collection -%}
      <div class="oduree-crosssell-scroll">
        {%- for p in block.settings.collection.products limit: block.settings.max_products -%}
          <div class="oduree-crosssell-card">
            <div class="oduree-crosssell-card__img">
              {%- if p.featured_image -%}
                <img src="{{ p.featured_image | image_url: width: 300 }}" alt="{{ p.title | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="oduree-crosssell-card__info">
              <div class="oduree-crosssell-card__name">{{ p.title }}</div>
              <div class="oduree-crosssell-card__price">
                {%- if p.compare_at_price > p.price -%}<span class="old">{{ p.compare_at_price | money }}</span>{%- endif -%}
                {{ p.price | money }}
              </div>
            </div>
            <a href="{{ p.url }}" class="oduree-crosssell-card__btn">Bekijk product</a>
          </div>
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>

  {%- when 'cta_banner' -%}
    <div class="oduree-section-block" {{ block.shopify_attributes }}>
      <div class="oduree-cta-banner" style="background:{{ block.settings.background_color | default: '#2C2C2A' }};color:#fff;">
        <p class="oduree-cta-banner__title">{{ block.settings.heading }}</p>
        <p class="oduree-cta-banner__sub">{{ block.settings.subheading }}</p>
        <button class="oduree-cta-banner__btn" style="background:{{ block.settings.button_color | default: '#C9A84C' }};" onclick="window.scrollTo({top:0,behavior:'smooth'})">{{ block.settings.button_text }}</button>
      </div>
    </div>

  {%- when 'trust_footer' -%}
    <div class="oduree-trust-footer" {{ block.shopify_attributes }}>
      <div class="oduree-trust-footer__item"><span>{{ block.settings.trust_1_icon }}</span> {{ block.settings.trust_1_text }}</div>
      <div class="oduree-trust-footer__item"><span>{{ block.settings.trust_2_icon }}</span> {{ block.settings.trust_2_text }}</div>
      <div class="oduree-trust-footer__item"><span>{{ block.settings.trust_3_icon }}</span> {{ block.settings.trust_3_text }}</div>
      <div class="oduree-trust-footer__item"><span>{{ block.settings.trust_4_icon }}</span> {{ block.settings.trust_4_text }}</div>
    </div>

  {%- endcase -%}
{%- endfor -%}
</div>

<!-- ════════════ STICKY BAR ════════════ -->
{%- if section.settings.sticky_buy_button_enabled -%}
<div class="oduree-sticky-bar" id="odureeStickyBar">
  <div class="oduree-sticky-bar__prices">
    {%- if current_variant.compare_at_price > current_variant.price -%}
      <span class="oduree-sticky-bar__old" id="odureeStickyOld">{{ current_variant.compare_at_price | money }}</span>
    {%- endif -%}
    <span class="oduree-sticky-bar__price" id="odureeStickyPrice">{{ current_variant.price | money }}</span>
  </div>
  <button class="oduree-sticky-bar__btn" onclick="document.getElementById('odureeForm').requestSubmit()">{{ section.settings.atc_button_text }}</button>
</div>
{%- endif -%}

</div>

<script>
(function() {
  // ─── Gallery Slider ───
  var currentSlide = 0;
  var track = document.getElementById('galleryTrack');
  var dots = document.querySelectorAll('.oduree-gallery__dot');
  var thumbs = document.querySelectorAll('.oduree-gallery__thumb');
  var totalSlides = dots.length;

  window.odureeGoTo = function(idx) {
    if (idx < 0) idx = totalSlides - 1;
    if (idx >= totalSlides) idx = 0;
    currentSlide = idx;
    if (track) track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    dots.forEach(function(d, i) { d.classList.toggle('oduree-gallery__dot--active', i === idx); });
    thumbs.forEach(function(t, i) { t.classList.toggle('oduree-gallery__thumb--active', i === idx); });
  };
  window.odureeSlider = function(dir) { odureeGoTo(currentSlide + dir); };

  // Touch swipe
  var startX = 0;
  var gallery = document.getElementById('odureeGallery');
  if (gallery) {
    gallery.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    gallery.addEventListener('touchend', function(e) {
      var diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) odureeSlider(diff > 0 ? 1 : -1);
    }, { passive: true });
  }

  // ─── Variant Selection ───
  window.odureeSelectVariant = function(el) {
    document.querySelectorAll('.oduree-variant-card').forEach(function(c) { c.classList.remove('oduree-variant-card--active'); });
    el.classList.add('oduree-variant-card--active');
    var vid = el.dataset.variantId;
    document.getElementById('odureeVariantInput').value = vid;
    var url = new URL(window.location);
    url.searchParams.set('variant', vid);
    history.replaceState({}, '', url);
  };

  // ─── Abo Toggle ───
  window.odureeSetMode = function(mode) {
    var btns = document.querySelectorAll('.oduree-toggle__option');
    btns.forEach(function(b) { b.classList.toggle('oduree-toggle__option--active', b.dataset.mode === mode); });
  };

  // ─── Bundel Toggle ───
  window.odureeBundelToggle = function() {
    var panel = document.getElementById('odureeBundelPanel');
    if (panel) panel.classList.toggle('oduree-bundel__panel--open');
    var arrow = document.getElementById('odureeBundelArrow');
    if (arrow) arrow.style.transform = panel.classList.contains('oduree-bundel__panel--open') ? 'rotate(180deg)' : '';
  };

  // ─── Sticky Bar: show when ATC is out of view ───
  var atcBtn = document.getElementById('odureeATC');
  var stickyBar = document.getElementById('odureeStickyBar');
  if (atcBtn && stickyBar) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        stickyBar.classList.toggle('oduree-sticky-bar--visible', !entry.isIntersecting);
      });
    }, { threshold: 0 });
    observer.observe(atcBtn);
  }
})();
</script>

