<!-- ════════════ JAVASCRIPT ════════════ -->

<script>

// ─── State ───
var isAbo = false;
var bundelOpen = false;
var isBundelSelected = false;
var huidigeBundel = 'b1';
var basePrice = 17.95;
var geuren = [
  'Savage',
  'Million',
  'Arabian Tonka',
  'La Vie est Bel',
  'Lady Millionaire',
  'Boss Bottle',
  'Spicebom',
  'Coco Vanilla',
  'Invictos',
  'Black Opum',
  'Strong with You',
  'Oud Wood',
  'Alian',
  'Home Intense',
  'Skandal',
  'Jadore',
  'Libra',
  'Good Gurl',
  'Blue',
  'Mis Dioor'
];
var bundelBase = {
  b1: { stuks: 2, prijs: 35.90, giftWaarde: 4.95, giftLabel: '1 cadeau', giftCount: 1 },
  b2: { stuks: 5, prijs: 89.75, giftWaarde: 24.90, giftLabel: '2 cadeaus', giftCount: 2 },
  b3: { stuks: 10, prijs: 179.50, giftWaarde: 74.80, giftLabel: '4 cadeaus', giftCount: 4 }
};

// Extra period per bundel
var bundelPeriods = {
  b1: { label: 'Elke 2 maanden', summaryLabel: 'Elke 2 maanden' },
  b2: { label: 'Elke 3 maanden', summaryLabel: 'Elke 3 maanden' },
  b3: { label: 'Elke 6 maanden', summaryLabel: 'Elke 6 maanden' }
};

// ─── Helpers ───
function fmt(n) {
  return '€' + n.toFixed(2).replace('.', ',');
}

function calcBadge(oldP, newP) {
  var diff = oldP - newP;
  if (diff >= 100) return '-€' + Math.round(diff);
  return '-' + Math.round((diff / oldP) * 100) + '%';
}

// ═══════════════════════════════════════
// CENTRAL PRICE UPDATE — syncs everything
// ═══════════════════════════════════════
function updateAllPrices() {
  var currentBase, currentAbo, beforePrice;
  var isBundel = isBundelSelected && bundelOpen;

  if (isBundel) {
    var bd = bundelBase[huidigeBundel];
    currentBase = bd.prijs;
    currentAbo = Math.round(bd.prijs * 0.8 * 100) / 100;
    // Before = productprijs + gift t.w.v. (gifts zijn gratis, dus perceived value hoger)
    beforePrice = Math.round((bd.prijs + bd.giftWaarde) * 100) / 100;
  } else {
    currentBase = basePrice;
    currentAbo = Math.round(basePrice * 0.8 * 100) / 100;
    beforePrice = basePrice;
  }

  var showPrice = isAbo ? currentAbo : currentBase;
  // Korting zichtbaar bij abo OF bundel (want gifts = gratis korting)
  var hasDiscount = isAbo || isBundel;

  // ── Main price row ──
  document.getElementById('priceDisplay').textContent = fmt(showPrice);
  document.getElementById('oldPrice').textContent = fmt(beforePrice);
  document.getElementById('oldPrice').style.display = hasDiscount ? 'inline' : 'none';
  document.getElementById('mainBadge').style.display = hasDiscount ? 'inline' : 'none';
  if (hasDiscount) document.getElementById('mainBadge').textContent = calcBadge(beforePrice, showPrice);

  // ── Image badge ──
  document.getElementById('imgBadge').style.display = hasDiscount ? 'block' : 'none';
  if (hasDiscount) document.getElementById('imgBadge').textContent = calcBadge(beforePrice, showPrice);

  // ── Eenmalig card ──
  document.getElementById('optEenmaligPrice').textContent = fmt(currentBase);

  // ── Abo card ──
  document.getElementById('optAboOld').textContent = fmt(isBundel ? beforePrice : currentBase);
  document.getElementById('optAboNew').textContent = fmt(currentAbo);
  document.getElementById('optAboBadge').textContent = calcBadge(isBundel ? beforePrice : currentBase, currentAbo);

  // ── Abo summary ──
  document.getElementById('aboSummaryPrice').textContent = fmt(currentAbo);

  // ── Sticky bar ──
  document.getElementById('stickyPrice').textContent = fmt(showPrice);
  document.getElementById('stickyOld').textContent = fmt(beforePrice);
  document.getElementById('stickyOld').style.display = hasDiscount ? 'inline' : 'none';
  document.getElementById('stickyBadge').style.display = hasDiscount ? 'inline' : 'none';
  if (hasDiscount) document.getElementById('stickyBadge').textContent = calcBadge(beforePrice, showPrice);

  // ── Bundel cart button (inside bundel section) ──
  if (bundelOpen) {
    var bdc = bundelBase[huidigeBundel];
    var bundelPrijs = isAbo ? Math.round(bdc.prijs * 0.8 * 100) / 100 : bdc.prijs;
    document.getElementById('bundelCartBtn').textContent = isAbo
      ? 'Bundel abonneren — ' + fmt(bundelPrijs) + '/levering'
      : 'Bundel toevoegen — ' + fmt(bundelPrijs);
  }

  // ── Main + sticky button text ──
  var cartText;
  if (isBundel) {
    var bd2 = bundelBase[huidigeBundel];
    var bp = isAbo ? Math.round(bd2.prijs * 0.8 * 100) / 100 : bd2.prijs;
    cartText = isAbo
      ? 'Bundel abonneren — ' + fmt(bp) + '/levering'
      : 'Bundel toevoegen — ' + fmt(bp);
  } else {
    cartText = isAbo ? 'Abonneer & bespaar 20%' : 'Voeg toe aan winkelwagen';
  }
  document.getElementById('cartBtn').textContent = cartText;
  document.getElementById('stickyBtn').textContent = cartText;

  // ── Gratis verzending logica: alleen bij abo OF totaal ≥ €50 ──
  var gratisVerzending = isAbo || showPrice >= 50;
  document.getElementById('shippingText').textContent = gratisVerzending
    ? 'Gratis verzending'
    : 'Gratis verzending vanaf €50';
  var bvEl = document.getElementById('bundelVerzendingVoordeel');
  if (bvEl) {
    var bundelTotaal = bundelBase[huidigeBundel].prijs;
    if (isAbo) bundelTotaal = Math.round(bundelTotaal * 0.8 * 100) / 100;
    bvEl.style.display = (isAbo || bundelTotaal >= 50) ? 'flex' : 'none';
  }
}

// ─── Image Slider (scroll-snap based) ───
var currentSlide = 0;
var totalSlides = 5;

function slideTo(idx) {
  currentSlide = Math.max(0, Math.min(idx, totalSlides - 1));
  var track = document.getElementById('sliderTrack');
  var slideW = track.children[0].offsetWidth;
  track.scrollTo({ left: currentSlide * slideW, behavior: 'smooth' });
  updateSliderUI();
}

function slideNav(dir) {
  slideTo(currentSlide + dir);
}

function updateSliderUI() {
  // Progress bar
  document.getElementById('sliderProgress').style.width = ((currentSlide + 1) / totalSlides * 100) + '%';
  // Thumbnails
  document.querySelectorAll('.thumb').forEach(function(t, i) { t.classList.toggle('active', i === currentSlide); });
  // Arrows
  document.getElementById('sliderPrev').disabled = currentSlide === 0;
  document.getElementById('sliderNext').disabled = currentSlide === totalSlides - 1;
  // Shadow: hide on last slide
  document.getElementById('sliderShadow').style.opacity = currentSlide === totalSlides - 1 ? '0' : '1';
  // Scroll thumb into view
  var activeThumb = document.getElementById('thumbsRow').children[currentSlide];
  if (activeThumb) activeThumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
}

// Listen to native scroll to detect slide changes (swipe/drag)
(function() {
  var track = document.getElementById('sliderTrack');
  var scrollTimer;
  track.addEventListener('scroll', function() {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(function() {
      var slideW = track.children[0].offsetWidth;
      var newIdx = Math.round(track.scrollLeft / slideW);
      if (newIdx !== currentSlide) {
        currentSlide = newIdx;
        updateSliderUI();
      }
    }, 60);
  }, { passive: true });
})();

// ─── Geur kiezer toggle ───
function toggleGeurKiezer() {
  var picker = document.getElementById('geurPicker');
  var btn = document.querySelector('.geur-toggle');
  var isOpen = picker.style.display !== 'none';
  picker.style.display = isOpen ? 'none' : 'block';
  btn.classList.toggle('open', !isOpen);
}

// Geur pill click — in Shopify this navigates to the variant URL
document.querySelectorAll('.geur-pill').forEach(function(pill) {
  pill.addEventListener('click', function() {
    document.querySelectorAll('.geur-pill').forEach(function(p) { p.classList.remove('active'); });
    pill.classList.add('active');
    // In Shopify: window.location.href = variant URL
  });
});

// ─── Period selector ───
function selectPeriod(id, label) {
  ['p1', 'p2', 'p3', 'p4'].forEach(function(p) {
    var el = document.getElementById(p);
    if (el.style.display !== 'none') {
      el.classList.remove('active');
      el.style.border = '1px solid #d8cdb8';
    }
  });
  var sel = document.getElementById(id);
  sel.classList.add('active');
  sel.style.border = '2px solid #2C2C2A';
  document.getElementById('aboSummaryPeriod').textContent = label;
}

// ─── Update period tabs based on bundel state ───
function updatePeriodTabs() {
  var grid = document.getElementById('periodGrid');
  var p4 = document.getElementById('p4');

  if (isBundelSelected && bundelOpen) {
    // Always show 4 fixed tabs when bundel is open
    p4.textContent = 'Elke 6 maanden';
    p4.setAttribute('onclick', "selectPeriod('p4','Elke 6 maanden')");
    p4.style.display = '';
    grid.style.gridTemplateColumns = 'repeat(4, 1fr)';

    // Preselect based on bundel size
    var preselect = { b1: ['p2', 'Elke 2 maanden'], b2: ['p3', 'Elke 3 maanden'], b3: ['p4', 'Elke 6 maanden'] };
    var ps = preselect[huidigeBundel];
    selectPeriod(ps[0], ps[1]);
  } else {
    p4.style.display = 'none';
    grid.style.gridTemplateColumns = 'repeat(3, 1fr)';
    selectPeriod('p1', 'Elke maand');
  }
}

// ─── Eenmalig / Abo toggle ───
function selectOpt(opt) {
  isAbo = opt === 'abo';

  var optE = document.getElementById('optEenmalig');
  var optA = document.getElementById('optAbo');
  optE.classList.toggle('active', !isAbo);
  optE.style.border = isAbo ? '0.5px solid #ccc' : '2px solid #2C2C2A';
  optA.classList.toggle('active', isAbo);
  optA.style.border = isAbo ? '2px solid #2C2C2A' : '0.5px solid #ccc';

  document.getElementById('aboSection').style.display = isAbo ? 'block' : 'none';

  if (isAbo) updatePeriodTabs();

  // Update bundel abo badge
  if (bundelOpen) {
    document.getElementById('aboBundelBadge').style.display = isAbo ? 'flex' : 'none';
    updateBundelCardPrices();
  }

  updateAllPrices();
}

// ─── Bundel card prices (inside the bundel section only) ───
function updateBundelCardPrices() {
  Object.keys(bundelBase).forEach(function(id) {
    var d = bundelBase[id];
    var beforePrijs = Math.round((d.prijs + d.giftWaarde) * 100) / 100;
    var afterPrijs = isAbo ? Math.round(d.prijs * 0.8 * 100) / 100 : d.prijs;
    // Always show before price (includes gift value)
    document.getElementById(id + '-old').style.display = 'inline';
    document.getElementById(id + '-old').textContent = fmt(beforePrijs);
    document.getElementById(id + '-new').textContent = fmt(afterPrijs);
    // Always show badge (gifts = free = discount)
    document.getElementById(id + '-badge').style.display = 'inline';
    document.getElementById(id + '-badge').textContent = calcBadge(beforePrijs, afterPrijs);
  });
}

// ─── Bundel toggle ───
function toggleBundel() {
  bundelOpen = !bundelOpen;
  document.getElementById('bundelSection').style.display = bundelOpen ? 'block' : 'none';
  document.getElementById('bundelArrow').style.transform = bundelOpen ? 'rotate(180deg)' : 'rotate(0)';

  if (bundelOpen) {
    updateBundelCardPrices();
    buildGeurSlots(bundelBase[huidigeBundel].stuks);
    updateGiftUnlocks(bundelBase[huidigeBundel].stuks);
    // Auto-select first bundel when opening
    isBundelSelected = true;
  } else {
    // Closing bundel: deselect bundel, go back to single product
    isBundelSelected = false;
  }

  document.getElementById('aboBundelBadge').style.display = (bundelOpen && isAbo) ? 'flex' : 'none';
  updatePeriodTabs();
  updateAllPrices();
}

// ─── Select bundel card ───
function selectBundel(id, stuks) {
  Object.keys(bundelBase).forEach(function(b) {
    var el = document.getElementById(b);
    el.classList.remove('active');
    el.style.border = '0.5px solid #ccc';
  });
  var sel = document.getElementById(id);
  sel.classList.add('active');
  sel.style.border = '2px solid #2C2C2A';
  huidigeBundel = id;
  isBundelSelected = true;
  buildGeurSlots(stuks);
  updateGiftUnlocks(stuks);
  updatePeriodTabs();
  updateAllPrices();
}

// ─── Gift unlock/lock logic ───
var giftConfig = [
  { id: 'gift1', minStuks: 2 },   // Spray Sample
  { id: 'gift2', minStuks: 5 },   // Premium Speelkaarten
  { id: 'gift3', minStuks: 10 },  // Giftbox
  { id: 'gift4', minStuks: 10 }   // Signature Paraplu
];

function updateGiftUnlocks(stuks) {
  giftConfig.forEach(function(g) {
    var el = document.getElementById(g.id);
    if (!el) return;
    var unlocked = stuks >= g.minStuks;
    el.classList.toggle('unlocked', unlocked);
    el.classList.toggle('locked', !unlocked);
    // Update badge text
    var badge = el.querySelector('.gift-gratis-badge');
    if (unlocked) {
      badge.textContent = 'Gratis';
      badge.classList.remove('locked-badge');
    } else {
      badge.textContent = 'Bij ' + g.minStuks + (g.minStuks < 10 ? '+' : '');
      badge.classList.add('locked-badge');
    }
    // Toggle lock overlay
    var lock = el.querySelector('.gift-lock-overlay');
    if (lock) lock.style.display = unlocked ? 'none' : 'flex';
  });
}

// ─── Build geur dropdowns ───
function buildGeurSlots(aantal) {
  var c = document.getElementById('geurSlots');
  document.getElementById('geurAantal').textContent = aantal;
  c.innerHTML = '';
  for (var i = 0; i < aantal; i++) {
    var row = document.createElement('div');
    row.className = 'geur-slot';
    var lbl = document.createElement('label');
    lbl.textContent = 'Geur ' + (i + 1);
    var sel = document.createElement('select');
    geuren.forEach(function(g, idx) {
      var opt = document.createElement('option');
      opt.value = g;
      opt.textContent = g;
      sel.appendChild(opt);
    });
    sel.selectedIndex = i % geuren.length;
    row.appendChild(lbl);
    row.appendChild(sel);
    c.appendChild(row);
  }
}

// ─── Accordion ───
function toggleAccordion(header) {
  var content = header.nextElementSibling;
  var icon = header.querySelector('.accordion-icon');
  var isOpen = content.style.display === 'block';
  
  document.querySelectorAll('.accordion-content').forEach(function(c) { c.style.display = 'none'; });
  document.querySelectorAll('.accordion-icon').forEach(function(i) { i.style.transform = 'rotate(0)'; });
  
  if (!isOpen) {
    content.style.display = 'block';
    icon.style.transform = 'rotate(180deg)';
  }
}

// ─── Sticky bar: show only when main ATC is out of view ───
(function() {
  var cartBtn = document.getElementById('cartBtn');
  var stickyBar = document.querySelector('.sticky-bar');
  if (cartBtn && stickyBar && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        stickyBar.classList.toggle('visible', !entry.isIntersecting);
      });
    }, { threshold: 0 });
    observer.observe(cartBtn);
  }
})();

</script>

